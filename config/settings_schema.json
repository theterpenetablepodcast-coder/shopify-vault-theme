[
  {
    "name": "theme_info",
    "theme_name": "Vault",
    "theme_version": "1.0.0",
    "theme_author": "Vault Theme",
    "theme_documentation_url": "https://github.com",
    "theme_support_url": "https://github.com"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_green",
        "label": "Accent green",
        "default": "#00ff41",
        "info": "Primary vault green — used for glows, CTAs, and highlights"
      },
      {
        "type": "color",
        "id": "color_silver",
        "label": "Silver",
        "default": "#c8cdd4"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Page background",
        "default": "#060606"
      },
      {
        "type": "color",
        "id": "color_panel",
        "label": "Card / panel background",
        "default": "#111111"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "select",
        "id": "font_display",
        "label": "Display font",
        "options": [
          { "value": "Orbitron",      "label": "Orbitron (default)" },
          { "value": "Share Tech Mono","label": "Share Tech Mono" },
          { "value": "Rajdhani",      "label": "Rajdhani" }
        ],
        "default": "Orbitron"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "Will be scaled down to 32×32px. Recommended: a small vault icon."
      }
    ]
  },
  {
    "name": "Effects",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_scanlines",
        "label": "Enable CRT scanlines overlay",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_matrix",
        "label": "Enable matrix rain on hero",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_cursor",
        "label": "Enable custom vault cursor",
        "default": true,
        "info": "Replaces the default mouse cursor with an animated vault dial"
      },
      {
        "type": "checkbox",
        "id": "enable_click_bursts",
        "label": "Enable click burst animations",
        "default": true,
        "info": "Spinning letters and code fragments appear on every click"
      },
      {
        "type": "checkbox",
        "id": "enable_preloader",
        "label": "Enable vault preloader",
        "default": true
      },
      {
        "type": "range",
        "id": "scanlines_opacity",
        "label": "Scanlines opacity",
        "min": 1,
        "max": 20,
        "step": 1,
        "unit": "%",
        "default": 8
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_twitter",
        "label": "X / Twitter URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube URL"
      }
    ]
  },
  {
    "name": "Checkout",
    "settings": [
      {
        "type": "image_picker",
        "id": "checkout_logo",
        "label": "Checkout logo"
      }
    ]
  }
]
