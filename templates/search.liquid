{% layout 'theme' %}

<div class="section">
  <div class="page-width">

    <div class="section-header" data-reveal>
      <p class="section-eyebrow">VAULT SEARCH</p>
      <h1 class="section-title" data-scramble-scroll>SEARCH CLASSIFIED FILES</h1>
    </div>

    <!-- Search form -->
    <form action="{{ routes.search_url }}" method="get" style="max-width:560px;margin:0 auto 60px;">
      <input type="hidden" name="type" value="product">
      <div style="display:flex;border:1px solid var(--clr-green);border-radius:var(--radius);overflow:hidden;box-shadow:var(--glow-green);">
        <input type="search"
               name="q"
               value="{{ search.terms | escape }}"
               placeholder="ENTER SEARCH CODE..."
               style="flex:1;background:var(--clr-panel);border:none;color:var(--clr-white);font-family:var(--font-mono);font-size:0.75rem;padding:14px 20px;outline:none;letter-spacing:0.1em;"
               aria-label="Search">
        <button type="submit"
                style="background:var(--clr-green);border:none;color:var(--clr-black);font-family:var(--font-mono);font-size:0.65rem;letter-spacing:0.2em;font-weight:700;padding:0 24px;text-transform:uppercase;">
          SCAN
        </button>
      </div>
    </form>

    {%- if search.performed -%}
      <p style="font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-silver-dim);text-align:center;margin-bottom:40px;letter-spacing:0.15em;text-transform:uppercase;">
        {%- if search.results_count > 0 -%}
          <span style="color:var(--clr-green);">{{ search.results_count }}</span> RESULTS FOUND FOR
          "<span style="color:var(--clr-white);">{{ search.terms }}</span>"
        {%- else -%}
          NO RESULTS FOR "<span style="color:var(--clr-white);">{{ search.terms }}</span>" — ACCESS DENIED
        {%- endif -%}
      </p>

      {%- if search.results_count > 0 -%}
        <div class="product-grid">
          {%- for result in search.results -%}
            {%- if result.object_type == 'product' -%}
              {%- render 'product-card', product: result, show_vendor: true -%}
            {%- else -%}
              <article class="vault-card" data-reveal>
                <div class="vault-card__body">
                  <p class="vault-card__category">{{ result.object_type | upcase }}</p>
                  <h3 class="vault-card__title"><a href="{{ result.url }}">{{ result.title }}</a></h3>
                </div>
              </article>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

    {%- endif -%}

  </div>
</div>
