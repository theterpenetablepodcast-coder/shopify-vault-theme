{% layout 'theme' %}

{%- liquid
  assign is_past_drop = false
  for tag in product.tags
    if tag == 'past-drop'
      assign is_past_drop = true
      break
    endif
  endfor

  assign is_club_product = false
  for col in product.collections
    if col.handle contains 'cultivator' or col.handle == 'the-uniform' or col.handle == 'the-drops'
      assign is_club_product = true
      break
    endif
  endfor
  if product.vendor contains 'Cultivat'
    assign is_club_product = true
  endif
-%}

<div class="section section--lg">
  <div class="page-width">

    <!-- Breadcrumb -->
    {%- if is_club_product -%}
      <nav class="breadcrumb" aria-label="Breadcrumb" style="font-family:'Montserrat',sans-serif;font-size:0.48rem;color:#A89F8C;letter-spacing:0.28em;text-transform:uppercase;margin-bottom:48px;display:flex;align-items:center;gap:10px;opacity:0.75;">
        <a href="{{ routes.root_url }}" style="color:#A89F8C;">Home</a>
        <span style="color:rgba(184,168,130,0.35);">·</span>
        {%- if collection -%}
          <a href="{{ collection.url }}" style="color:#A89F8C;">{{ collection.title }}</a>
          <span style="color:rgba(184,168,130,0.35);">·</span>
        {%- endif -%}
        <span style="color:#B8A882;">{{ product.title | truncate: 30 }}</span>
      </nav>
    {%- else -%}
      <nav class="breadcrumb" aria-label="Breadcrumb" style="font-family:var(--font-mono);font-size:0.6rem;color:var(--clr-silver-dim);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:40px;display:flex;align-items:center;gap:8px;">
        <a href="{{ routes.root_url }}" style="color:var(--clr-silver-dim);">HOME</a>
        <span style="color:var(--clr-green);">/</span>
        {%- if collection -%}
          <a href="{{ collection.url }}" style="color:var(--clr-silver-dim);">{{ collection.title | upcase }}</a>
          <span style="color:var(--clr-green);">/</span>
        {%- endif -%}
        <span style="color:var(--clr-green);">{{ product.title | upcase | truncate: 30 }}</span>
      </nav>
    {%- endif -%}

    <div class="product-layout">

      <!-- Gallery -->
      {%- comment -%}
        Prefer a video/external_video as the hero; fall back to variant image then media[0].
        product.media | where: "media_type", "video" returns all videos in the media set.
      {%- endcomment -%}
      {%- assign featured_media = product.media | where: "media_type", "video" | first -%}
      {%- if featured_media == blank -%}
        {%- assign featured_media = product.media | where: "media_type", "external_video" | first -%}
      {%- endif -%}
      {%- if featured_media == blank -%}
        {%- assign featured_media = product.selected_or_first_available_variant.featured_media | default: product.media[0] -%}
      {%- endif -%}
      <div class="product-gallery" data-reveal="left">
        <div class="product-gallery__main">

          {%- if featured_media.media_type == 'video' -%}
            <!-- Shopify-hosted video -->
            <video id="product-main-video" autoplay muted loop playsinline
                   style="background:#000;">
              {%- for source in featured_media.sources -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {%- endfor -%}
            </video>
            <img id="product-main-img"
                 src="{{ featured_media.preview_image | img_url: '800x800', crop: 'center' }}"
                 alt="{{ featured_media.alt | escape }}"
                 width="800" height="800" loading="eager"
                 style="display:none;">

          {%- elsif featured_media.media_type == 'external_video' -%}
            <!-- YouTube / Vimeo embed -->
            {%- if featured_media.host == 'youtube' -%}
              {%- assign embed_url = 'https://www.youtube.com/embed/' | append: featured_media.external_id | append: '?autoplay=1&mute=1&loop=1&playlist=' | append: featured_media.external_id -%}
            {%- else -%}
              {%- assign embed_url = 'https://player.vimeo.com/video/' | append: featured_media.external_id | append: '?autoplay=1&muted=1&loop=1' -%}
            {%- endif -%}
            <iframe id="product-main-iframe"
                    src="{{ embed_url }}"
                    allow="autoplay; encrypted-media" allowfullscreen
                    style="border:none;">
            </iframe>
            <img id="product-main-img"
                 src="{{ featured_media.preview_image | img_url: '800x800', crop: 'center' }}"
                 alt="{{ featured_media.alt | escape }}"
                 width="800" height="800" loading="eager"
                 style="display:none;">

          {%- elsif featured_media != blank -%}
            <!-- Image (from product.media) -->
            <img id="product-main-img"
                 src="{{ featured_media | img_url: '800x800', crop: 'center' }}"
                 alt="{{ featured_media.alt | escape }}"
                 width="800" height="800" loading="eager">

          {%- elsif product.featured_image -%}
            <!-- Fallback to featured_image -->
            <img id="product-main-img"
                 src="{{ product.featured_image | img_url: '800x800', crop: 'center' }}"
                 alt="{{ product.featured_image.alt | escape }}"
                 width="800" height="800" loading="eager">

          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            <img id="product-main-img" src="" alt="" style="display:none;">
          {%- endif -%}

          <!-- Corner brackets -->
          <div class="gallery-corner gallery-corner--tl"></div>
          <div class="gallery-corner gallery-corner--tr"></div>
          <div class="gallery-corner gallery-corner--bl"></div>
          <div class="gallery-corner gallery-corner--br"></div>
          <!-- Classification watermark — vault pages only -->
          {%- unless is_club_product -%}
            <div style="position:absolute;bottom:12px;left:12px;font-family:var(--font-mono);font-size:0.55rem;color:rgba(0,255,65,0.4);letter-spacing:0.25em;text-transform:uppercase;pointer-events:none;">
              VAULT // {{ product.id | md5 | slice: 0, 8 | upcase }}
            </div>
          {%- endunless -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="product-gallery__thumbs">
            {%- for media in product.media limit: 8 -%}
              {%- assign first_source = media.sources | first -%}
              <button class="thumb{% if forloop.first %} active{% endif %}"
                      data-media-type="{{ media.media_type }}"
                      {%- if media.media_type == 'video' -%}
                        data-video-src="{{ first_source.url }}"
                        data-video-type="{{ first_source.mime_type }}"
                        data-full="{{ media.preview_image | img_url: '800x800', crop: 'center' }}"
                      {%- elsif media.media_type == 'external_video' -%}
                        data-external-id="{{ media.external_id }}"
                        data-external-host="{{ media.host }}"
                        data-full="{{ media.preview_image | img_url: '800x800', crop: 'center' }}"
                      {%- else -%}
                        data-full="{{ media | img_url: '800x800', crop: 'center' }}"
                      {%- endif -%}
                      aria-label="View media {{ forloop.index }}">
                <img src="{{ media.preview_image | img_url: '150x150', crop: 'center' }}"
                     alt="{{ media.alt | escape }}"
                     width="72" height="72" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      <!-- /gallery -->

      <!-- Product info -->
      <div class="product-info" data-reveal="right">

        {%- if product.vendor != blank -%}
          <span class="product-info__badge">{{ product.vendor | upcase }}</span>
        {%- endif -%}

        {%- if is_club_product -%}
          <h1 class="cg-product__title">{{ product.title }}</h1>
        {%- else -%}
          <h1 class="product-info__title" data-scramble-scroll>{{ product.title }}</h1>
        {%- endif -%}

        <!-- Price -->
        <div class="product-info__price">
          <span class="price-current">
            {%- if product.price_varies -%}
              From {{ product.price_min | money }}
            {%- else -%}
              {{ product.price | money }}
            {%- endif -%}
          </span>
          {%- if product.compare_at_price > product.price -%}
            <span class="price-compare">{{ product.compare_at_price | money }}</span>
            <span class="price-save">
              SAVE {{ product.compare_at_price | minus: product.price | money }}
            </span>
          {%- endif -%}
        </div>

        <!-- Low stock indicator -->
        {%- assign current_variant = product.selected_or_first_available_variant -%}
        {%- if current_variant.inventory_management == 'shopify'
            and current_variant.inventory_policy != 'continue'
            and current_variant.inventory_quantity > 0
            and current_variant.inventory_quantity <= 5
            and is_past_drop == false -%}
          <p class="low-stock-badge">
            CRITICAL STOCK — {{ current_variant.inventory_quantity }} UNIT{% if current_variant.inventory_quantity > 1 %}S{% endif %} REMAINING
          </p>
        {%- endif -%}

        <!-- Variant data for JS -->
        <script type="application/json" id="product-variants-json">
          {{ product.variants | json }}
        </script>

        <!-- Variant selector -->
        {%- if product.has_only_default_variant == false -%}
          {%- for option in product.options_with_values -%}
            <div style="margin-bottom:20px;">
              <p class="variant-label" data-option-index="{{ forloop.index0 }}">
                {{ option.name | upcase }}
                <span class="variant-label__selected">
                  {%- assign selected_val = product.selected_or_first_available_variant.options[forloop.index0] -%}
                  {{ selected_val | default: option.values.first }}
                </span>
              </p>
              <div class="variant-btns">
                {%- for value in option.values -%}
                  <button class="variant-btn{% if forloop.first %} active{% endif %}"
                          data-option="{{ option.position }}"
                          data-value="{{ value | escape }}">
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}

        <!-- Add to cart form / archive state -->
        {%- if is_past_drop -%}
          <div class="past-drop-seal">
            <div class="past-drop-seal__bar"></div>
            <p class="past-drop-seal__headline">THIS DROP HAS BEEN SEALED</p>
            <p class="past-drop-seal__sub">VAULT CLOSED — SECURED BY THE FEW</p>
            <p class="past-drop-seal__body">
              This was a limited Cultivators Club release. Once gone, it leaves the vault permanently.
              Join the Discord to be first when the next drop opens.
            </p>
            <a href="https://discord.gg/mE8z5Defdc"
               target="_blank"
               rel="noopener noreferrer"
               class="btn btn--outline past-drop-seal__discord">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.033.055a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
              </svg>
              JOIN THE DISCORD — ACCESS NEXT DROP
            </a>
          </div>
        {%- else -%}
          <form method="post" action="/cart/add">
            {%- if product.available -%}
              <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">

              <!-- Quantity -->
              <p class="variant-label" style="margin-bottom:10px;">QUANTITY</p>
              <div class="qty-wrap" style="margin-bottom:20px;">
                <button type="button" class="qty-btn qty-minus" aria-label="Decrease quantity">–</button>
                <input type="number"
                       name="quantity"
                       class="qty-input"
                       value="1"
                       min="1"
                       aria-label="Quantity">
                <button type="button" class="qty-btn qty-plus" aria-label="Increase quantity">+</button>
              </div>

              {%- if is_club_product -%}
                <button type="submit" class="btn btn--cg atc-btn" data-atc>
                  <em>Secure Yours</em>
                </button>
                <a href="{{ routes.cart_url }}" class="btn btn--outline" style="width:100%;justify-content:center;margin-top:10px;">
                  View Cart
                </a>
              {%- else -%}
                <button type="submit" class="btn btn--primary atc-btn" data-atc>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="11" width="18" height="11" rx="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                  </svg>
                  ADD TO VAULT
                </button>
                <a href="{{ routes.cart_url }}" class="btn btn--outline" style="width:100%;justify-content:center;">
                  VIEW VAULT CART
                </a>
              {%- endif -%}
            {%- else -%}
              {%- if is_club_product -%}
                <button type="button" class="btn btn--cg" style="opacity:0.4;pointer-events:none;" disabled>
                  <em>Sold Out</em>
                </button>
              {%- else -%}
                <button type="button" class="btn btn--outline" style="width:100%;justify-content:center;" disabled>
                  ACCESS DENIED — SOLD OUT
                </button>
              {%- endif -%}
            {%- endif -%}
          </form>
        {%- endif -%}

        <!-- Share -->
        <button type="button"
                class="share-btn"
                id="product-share-btn"
                data-url="{{ shop.url }}{{ product.url }}"
                data-title="{{ product.title | escape }}"
                aria-label="Share this product">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
          </svg>
          <span class="share-btn__label">{% if is_club_product %}Share{% else %}SHARE THIS DROP{% endif %}</span>
        </button>

        <!-- Meta info -->
        <div class="product-meta">
          {%- if product.vendor != blank -%}
            <p class="product-meta__item"><strong>{% if is_club_product %}DESIGNER{% else %}MANUFACTURER{% endif %}</strong> {{ product.vendor }}</p>
          {%- endif -%}
          {%- if product.type != blank -%}
            <p class="product-meta__item"><strong>{% if is_club_product %}CATEGORY{% else %}CLASSIFICATION{% endif %}</strong> {{ product.type }}</p>
          {%- endif -%}
          {%- unless is_club_product -%}
            <p class="product-meta__item"><strong>VAULT ID</strong> {{ product.id }}</p>
          {%- endunless -%}
          {%- if product.tags.size > 0 -%}
            <p class="product-meta__item">
              <strong>{% if is_club_product %}NOTES{% else %}TAGS{% endif %}</strong>
              {{ product.tags | join: ' · ' | upcase }}
            </p>
          {%- endif -%}
        </div>

        <!-- Accordion -->
        <div style="margin-top:28px;">
          {%- if product.description != blank -%}
            <div class="accordion-item">
              <button class="accordion-trigger open" aria-expanded="true">
                DESCRIPTION
                <svg class="acc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </button>
              <div class="accordion-body open" style="font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-silver-dim);line-height:1.9;">
                {{ product.description }}
              </div>
            </div>
          {%- endif -%}

          <div class="accordion-item">
            <button class="accordion-trigger" aria-expanded="false">
              SHIPPING & SECURITY
              <svg class="acc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </button>
            <div class="accordion-body" style="font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-silver-dim);line-height:1.9;">
              All vault orders are dispatched within 1-2 business days via tracked, insured courier.
              Packaging is discreet. All transactions encrypted with AES-256 protocol.
            </div>
          </div>

          <div class="accordion-item">
            <button class="accordion-trigger" aria-expanded="false">
              RETURNS POLICY
              <svg class="acc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </button>
            <div class="accordion-body" style="font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-silver-dim);line-height:1.9;">
              Returns accepted within 30 days. Items must be in original vault-sealed condition.
              Contact our secure support channel to initiate a return protocol.
            </div>
          </div>
        </div>

      </div>
      <!-- /product info -->

    </div>
    <!-- /product layout -->

  </div>
</div>

<!-- ── YOU MAY ALSO SECURE ── -->
{%- assign related_collection = product.collections.first -%}
{%- if related_collection != blank -%}
  {%- assign related_products = related_collection.products | where: 'id', product.id | size -%}
  {%- assign related_count = related_collection.products.size | minus: 1 -%}
  {%- if related_count > 0 -%}

<div class="section" style="padding-top:0;border-top:1px solid var(--clr-border);">
  <div class="page-width">

    {%- if is_club_product -%}
      <div style="text-align:left;margin-bottom:40px;">
        <p style="font-family:'Montserrat',sans-serif;font-size:0.48rem;font-weight:500;letter-spacing:0.4em;color:#A89F8C;text-transform:uppercase;margin:0 0 14px;opacity:0.8;">{{ related_collection.title }}</p>
        <h2 style="font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:300;color:#EDE8DC;letter-spacing:0.02em;margin:0;">You May Also <em style="font-style:italic;">Like</em></h2>
      </div>
    {%- else -%}
      <div class="section-header" style="margin-bottom:40px;">
        <p class="section-eyebrow" style="justify-content:flex-start;">{{ related_collection.title | upcase }}</p>
        <h2 class="section-title" style="text-align:left;" data-scramble-scroll>YOU MAY ALSO SECURE</h2>
      </div>
    {%- endif -%}

    <div class="product-grid{% if is_club_product %} product-grid--club{% endif %}" style="grid-template-columns:repeat(auto-fill,minmax(260px,1fr));">
      {%- for rel in related_collection.products limit: 4 -%}
        {%- unless rel.id == product.id -%}
          {%- render 'product-card', product: rel, show_vendor: false -%}
        {%- endunless -%}
      {%- endfor -%}
    </div>

  </div>
</div>

  {%- endif -%}
{%- endif -%}

<script>
(function(){
  var btn = document.getElementById('product-share-btn');
  if (!btn) return;
  var url   = btn.dataset.url;
  var title = btn.dataset.title;
  var label = btn.querySelector('.share-btn__label');

  btn.addEventListener('click', function(){
    if (navigator.share) {
      navigator.share({ title: title, url: url }).catch(function(){});
    } else {
      navigator.clipboard.writeText(url).then(function(){
        btn.classList.add('copied');
        label.textContent = 'LINK COPIED';
        setTimeout(function(){
          btn.classList.remove('copied');
          label.textContent = 'SHARE THIS DROP';
        }, 2200);
      }).catch(function(){});
    }
  });
})();
</script>
