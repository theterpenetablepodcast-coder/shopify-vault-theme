{% layout 'theme' %}

<div class="section" style="min-height:70vh;display:flex;align-items:center;justify-content:center;">
  <div style="width:100%;max-width:440px;padding:0 24px;" data-reveal>

    <div style="text-align:center;margin-bottom:40px;">
      <p class="section-eyebrow">NEW CLEARANCE</p>
      <h1 class="section-title" data-scramble-scroll>REQUEST ACCESS</h1>
    </div>

    <div style="background:var(--clr-panel);border:1px solid var(--clr-border);padding:40px;">

      {%- form 'create_customer' -%}
        {%- if form.errors -%}
          <div style="background:rgba(255,34,34,0.1);border:1px solid #ff2222;padding:12px 16px;margin-bottom:24px;font-family:var(--font-mono);font-size:0.65rem;color:#ff2222;letter-spacing:0.1em;">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        {%- assign fields = 'First Name,customer[first_name],text,FIRST_NAME,given-name|Last Name,customer[last_name],text,LAST_NAME,family-name|Email,customer[email],email,EMAIL,email|Password,customer[password],password,SET PASSWORD,new-password' | split: '|' -%}
        {%- for field in fields -%}
          {%- assign f = field | split: ',' -%}
          <div style="margin-bottom:20px;">
            <label style="font-family:var(--font-mono);font-size:0.6rem;color:var(--clr-silver-dim);letter-spacing:0.25em;text-transform:uppercase;display:block;margin-bottom:8px;">
              {{ f[3] }}
            </label>
            <input type="{{ f[2] }}"
                   name="{{ f[1] }}"
                   autocomplete="{{ f[4] }}"
                   style="width:100%;background:var(--clr-dark);border:1px solid var(--clr-border);color:var(--clr-white);font-family:var(--font-mono);font-size:0.75rem;padding:12px 16px;border-radius:var(--radius);outline:none;transition:border-color 0.3s;{% if f[2] == 'password' %}letter-spacing:0.3em;{% endif %}"
                   onfocus="this.style.borderColor='var(--clr-green)'"
                   onblur="this.style.borderColor='var(--clr-border)'">
          </div>
        {%- endfor -%}

        <button type="submit" class="btn btn--primary" style="width:100%;justify-content:center;height:50px;font-size:0.75rem;letter-spacing:0.25em;margin-top:8px;">
          SUBMIT REQUEST
        </button>

      {%- endform -%}

      <div style="text-align:center;margin-top:20px;">
        <a href="{{ routes.account_login_url }}"
           style="font-family:var(--font-mono);font-size:0.6rem;color:var(--clr-silver-dim);letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;"
           onmouseover="this.style.color='var(--clr-green)'"
           onmouseout="this.style.color='var(--clr-silver-dim)'">
          ALREADY HAVE ACCESS? LOGIN →
        </a>
      </div>

    </div>

  </div>
</div>
