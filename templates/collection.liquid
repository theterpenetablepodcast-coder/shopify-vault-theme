      <!-- ── THE KIT AND CARRY ── -->
      <a href="/collections/the-kit-and-carry" class="club-entry club-entry--kit" aria-label="Enter The Kit and Carry">
        <div class="club-entry__visual">
          {%- if kit_col.image -%}
            <img src="{{ kit_col.image | img_url: '900x700', crop: 'center' }}" alt="{{ kit_col.title | escape }}" width="900" height="700" loading="lazy">
          {%- elsif kit_col.products.first.featured_image -%}
            <img src="{{ kit_col.products.first.featured_image | img_url: '900x700', crop: 'center' }}" alt="{{ kit_col.title | escape }}" width="900" height="700" loading="lazy">
          {%- else -%}
            <img src="{{ 'collection-the-kit-and-carry.png' | asset_url }}" alt="The Kit and Carry" width="900" height="700" loading="lazy">
          {%- endif -%}
          <div class="club-entry__overlay club-entry__overlay--steel"></div>
          <div class="club-entry__bracket club-entry__bracket--tl club-entry__bracket--steel"></div>
          <div class="club-entry__bracket club-entry__bracket--br club-entry__bracket--steel"></div>
          <div class="club-entry__count-badge club-entry__count-badge--steel">{{ kit_col.products_count }}<span>ITEMS</span></div>
        </div>
        <div class="club-entry__body club-entry__body--steel">
          <div>
            <p class="club-entry__eyebrow club-entry__eyebrow--steel">ACCESSORIES</p>
            <h3 class="club-entry__title club-entry__title--steel">THE KIT AND CARRY</h3>
            <p class="club-entry__desc">Caps, bags, and everything in between. The details that finish the look and carry the brand.</p>
          </div>
          <div class="club-entry__foot">
            <span class="club-entry__cta club-entry__cta--steel">ENTER<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
          </div>
        </div>
      </a>

    </div>
  </div>
</div>

<style>
/* ── WRC accent: green (The Movement) ── */
.club-entry__no-img--green {
  background: repeating-linear-gradient(-45deg, #040d05, #040d05 10px, #020802 10px, #020802 20px);
}
.club-entry__overlay--green {
  background: linear-gradient(to top, rgba(0,20,5,0.75) 0%, transparent 55%);
}
.club-entry__bracket--green       { border-color: rgba(0,255,65,0.45); }
.club-entry:hover .club-entry__bracket--green { border-color: #00ff41; box-shadow: 0 0 10px rgba(0,255,65,0.4); }
.club-entry__count-badge--green   { border-color: rgba(0,255,65,0.35); color: var(--clr-green); }
.club-entry__body--green          { background: #020d03; border-top-color: rgba(0,255,65,0.12); }
.club-entry:hover .club-entry__body--green { border-top-color: rgba(0,255,65,0.3); }
.club-entry__eyebrow--green       { color: rgba(0,255,65,0.65); }
.club-entry__title--green         { color: var(--clr-green); }
.club-entry:hover .club-entry__title--green { color: #33ff6a; }
.club-entry__cta--green           { color: var(--clr-green); }
.club-entry:hover .club-entry__cta--green { color: #33ff6a; gap: 12px; }
.club-entry--movement::before     { background: linear-gradient(90deg, transparent, #00ff41, transparent); }

/* ── WRC accent: steel/chrome (The Kit and Carry) ── */
.club-entry__no-img--steel {
  background: repeating-linear-gradient(-45deg, #0c0d0e, #0c0d0e 10px, #080909 10px, #080909 20px);
}
.club-entry__overlay--steel {
  background: linear-gradient(to top, rgba(5,8,10,0.75) 0%, transparent 55%);
}
.club-entry__bracket--steel       { border-color: rgba(160,170,185,0.45); }
.club-entry:hover .club-entry__bracket--steel { border-color: #a0aabb; box-shadow: 0 0 8px rgba(160,170,185,0.35); }
.club-entry__count-badge--steel   { border-color: rgba(160,170,185,0.3); color: #a0aabb; }
.club-entry__body--steel          { background: #0a0c0d; border-top-color: rgba(160,170,185,0.1); }
.club-entry:hover .club-entry__body--steel { border-top-color: rgba(160,170,185,0.25); }
.club-entry__eyebrow--steel       { color: rgba(160,170,185,0.65); }
.club-entry__title--steel         { color: #a0aabb; }
.club-entry:hover .club-entry__title--steel { color: #c0ccd8; }
.club-entry__cta--steel           { color: #a0aabb; }
.club-entry:hover .club-entry__cta--steel  { color: #c0ccd8; gap: 12px; }
.club-entry--kit::before          { background: linear-gradient(90deg, transparent, #a0aabb, transparent); }

/* ── WRC desktop: 4 columns (mobile handled in shared block above) ── */
@media (min-width: 901px) {
  .wrc-entries { grid-template-columns: repeat(4, 1fr); }
}
</style>
{%- endif -%}


<!-- ============================================================
     COLLECTION BODY — filters + products
============================================================ -->
{%- unless is_hub or is_wrc_hub -%}
<div class="section" {% if is_club %}style="background:#080808;"{% endif %}>
  <div class="page-width">

    <div class="collection-layout">

      <!-- Filter Sidebar -->
      <aside class="filter-panel" aria-label="Collection filters">
        <div class="filter-panel__title">FILTERS</div>

        {%- for filter in collection.filters -%}
          <div class="filter-group">
            <p class="filter-group__label">{{ filter.label | upcase }}</p>

            {%- case filter.type -%}
              {%- when 'list' -%}
                {%- for value in filter.values -%}
                  <div class="filter-option">
                    <input type="checkbox"
                           id="filter-{{ filter.param_name }}-{{ forloop.index }}"
                           name="{{ filter.param_name }}"
                           value="{{ value.value }}"
                           {% if value.active %}checked{% endif %}
                           {% if value.count == 0 and value.active == false %}disabled{% endif %}
                           onchange="this.form.submit()">
                    <label for="filter-{{ filter.param_name }}-{{ forloop.index }}">
                      {{ value.label }} ({{ value.count }})
                    </label>
                  </div>
                {%- endfor -%}

              {%- when 'price_range' -%}
                <div style="display:flex;gap:8px;align-items:center;">
                  <input type="number"
                         name="{{ filter.min_value.param_name }}"
                         value="{{ filter.min_value.value | money_without_currency | remove: ',' }}"
                         min="0"
                         max="{{ filter.range_max | money_without_currency | remove: ',' }}"
                         style="background:var(--clr-dark);border:1px solid var(--clr-border);color:var(--clr-white);font-family:var(--font-mono);font-size:0.65rem;padding:6px 10px;width:80px;border-radius:var(--radius);outline:none;"
                         placeholder="MIN"
                         aria-label="Minimum price">
                  <span style="color:var(--clr-silver-dim);font-family:var(--font-mono);font-size:0.65rem;">—</span>
                  <input type="number"
                         name="{{ filter.max_value.param_name }}"
                         value="{{ filter.max_value.value | money_without_currency | remove: ',' }}"
                         min="0"
                         max="{{ filter.range_max | money_without_currency | remove: ',' }}"
                         style="background:var(--clr-dark);border:1px solid var(--clr-border);color:var(--clr-white);font-family:var(--font-mono);font-size:0.65rem;padding:6px 10px;width:80px;border-radius:var(--radius);outline:none;"
                         placeholder="MAX"
                         aria-label="Maximum price">
                </div>
            {%- endcase -%}
          </div>
        {%- endfor -%}

        {%- if collection.filters.size > 0 -%}
          <a href="{{ collection.url }}" class="btn btn--ghost" style="width:100%;justify-content:center;font-size:0.65rem;padding:10px 16px;margin-top:12px;">
            CLEAR FILTERS
          </a>
        {%- endif -%}
      </aside>

      <!-- Products -->
      <div>
        <!-- Toolbar -->
        <div class="collection-toolbar">
          <p class="collection-count">
            <span>{{ collection.products_count }}</span> ITEMS SECURED
          </p>

          <select class="sort-select" aria-label="Sort products"
                  onchange="window.location = '{{ collection.url }}?sort_by=' + this.value">
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            <option value="manual"             {% if sort_by == 'manual' %}selected{% endif %}>FEATURED</option>
            <option value="best-selling"       {% if sort_by == 'best-selling' %}selected{% endif %}>BEST SELLING</option>
            <option value="title-ascending"    {% if sort_by == 'title-ascending' %}selected{% endif %}>A–Z</option>
            <option value="title-descending"   {% if sort_by == 'title-descending' %}selected{% endif %}>Z–A</option>
            <option value="price-ascending"    {% if sort_by == 'price-ascending' %}selected{% endif %}>PRICE: LOW</option>
            <option value="price-descending"   {% if sort_by == 'price-descending' %}selected{% endif %}>PRICE: HIGH</option>
            <option value="created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>NEWEST</option>
          </select>
        </div>

        {%- paginate collection.products by 24 -%}
          {%- if collection.products.size > 0 -%}
            <div class="product-grid{% if is_club %} product-grid--club{% endif %}">
              {%- for product in collection.products -%}
                {%- render 'product-card', product: product, show_vendor: true -%}
              {%- endfor -%}
            </div>

            {%- if paginate.pages > 1 -%}
              <nav style="margin-top:48px;display:flex;align-items:center;justify-content:center;gap:8px;" aria-label="Pagination">
                {%- if paginate.previous -%}
                  <a href="{{ paginate.previous.url }}" class="btn btn--outline" style="padding:10px 16px;font-size:0.65rem;">← PREV</a>
                {%- endif -%}
                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}" class="btn btn--outline" style="padding:10px 16px;font-size:0.65rem;">{{ part.title }}</a>
                  {%- else -%}
                    <span style="font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-green);padding:10px 16px;border:1px solid var(--clr-green);">{{ part.title }}</span>
                  {%- endif -%}
                {%- endfor -%}
                {%- if paginate.next -%}
                  <a href="{{ paginate.next.url }}" class="btn btn--outline" style="padding:10px 16px;font-size:0.65rem;">NEXT →</a>
                {%- endif -%}
              </nav>
            {%- endif -%}

          {%- else -%}
            <div style="text-align:center;padding:80px 0;">
              <p style="font-family:var(--font-display);font-size:1.2rem;color:var(--clr-silver-dim);letter-spacing:0.2em;">VAULT EMPTY</p>
              <p style="font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-silver-dim);margin-top:12px;">No items match your criteria.</p>
              <a href="{{ collection.url }}" class="btn btn--outline" style="margin-top:24px;">CLEAR FILTERS</a>
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>

    </div>
  </div>
</div>
{%- endunless -%}
