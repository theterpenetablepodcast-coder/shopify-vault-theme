{% layout 'theme' %}

{%- assign is_club = false -%}
{%- if collection.handle contains 'cultivator' -%}
  {%- assign is_club = true -%}
{%- endif -%}

<!-- ============================================================
     COLLECTION HERO — image fills top, text sits cleanly below
============================================================ -->

{%- if collection.image -%}
  <div style="width:100%;aspect-ratio:21/7;overflow:hidden;position:relative;background:var(--clr-black);">
    <img src="{{ collection.image | img_url: '2000x' }}"
         alt="{{ collection.title | escape }}"
         style="width:100%;height:100%;object-fit:cover;filter:brightness(0.7);"
         loading="eager">
    <!-- bottom fade so it bleeds cleanly into the text panel below -->
    <div style="position:absolute;bottom:0;left:0;right:0;height:50%;background:linear-gradient(to bottom,transparent,var(--clr-black));"></div>
    {%- if is_club -%}
      <!-- CLASSIFIED watermark on the image -->
      <div style="position:absolute;top:20px;left:50%;transform:translateX(-50%);font-family:var(--font-mono);font-size:0.6rem;color:rgba(0,255,65,0.6);letter-spacing:0.5em;text-transform:uppercase;white-space:nowrap;">
        ⬡ RESTRICTED ACCESS ⬡
      </div>
    {%- endif -%}
  </div>
{%- endif -%}

<!-- Text panel — always below the image -->
<div style="background:var(--clr-black);padding:{% if collection.image %}36px{% else %}72px{% endif %} 0 40px;border-bottom:1px solid var(--clr-border);text-align:center;">
  <div class="page-width">
    <p class="section-eyebrow">{% if is_club %}⬡ EXCLUSIVE ACCESS{% else %}VAULT CATEGORY{% endif %}</p>
    <h1 class="section-title" data-scramble-scroll>{{ collection.title | upcase }}</h1>
    {%- if collection.description != blank -%}
      <p style="font-family:var(--font-mono);font-size:0.8rem;color:var(--clr-silver-dim);letter-spacing:0.06em;max-width:640px;margin:16px auto 0;line-height:1.9;">
        {{ collection.description | strip_html }}
      </p>
    {%- endif -%}
  </div>
</div>


<!-- ============================================================
     VAULT-CRACK GATE — Cultivators Club only
============================================================ -->
{%- if is_club -%}
<div id="vault-gate">

  <!-- Dim overlay behind gate content -->
  <div id="vault-gate__bg"></div>

  <div id="vault-gate__panel">

    <!-- Spinning vault icon -->
    <div id="gate-icon" aria-hidden="true">
      <svg viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="80" cy="80" r="72" stroke="#1e1e1e" stroke-width="4"/>
        <!-- Tick marks -->
        {%- for i in (0..39) -%}
          {%- assign a = i | times: 9 -%}
          {%- assign mod5 = i | modulo: 5 -%}
          {%- assign mod10 = i | modulo: 10 -%}
          {%- if mod10 == 0 -%}
            <line x1="80" y1="10" x2="80" y2="22" stroke="#00ff41" stroke-width="2.5" transform="rotate({{ a }},80,80)"/>
          {%- elsif mod5 == 0 -%}
            <line x1="80" y1="11" x2="80" y2="21" stroke="#c8cdd4" stroke-width="1.5" transform="rotate({{ a }},80,80)"/>
          {%- else -%}
            <line x1="80" y1="13" x2="80" y2="19" stroke="#1e1e1e" stroke-width="1" transform="rotate({{ a }},80,80)"/>
          {%- endif -%}
        {%- endfor -%}
        <!-- Dial ring -->
        <circle id="gate-dial-ring" cx="80" cy="80" r="55" stroke="#00ff41" stroke-width="1.5" stroke-dasharray="6 4"/>
        <!-- Spokes -->
        <g id="gate-spokes">
          <line x1="80" y1="30" x2="80" y2="52" stroke="#7a8090" stroke-width="1.5"/>
          <line x1="80" y1="108" x2="80" y2="130" stroke="#7a8090" stroke-width="1.5"/>
          <line x1="30" y1="80" x2="52" y2="80" stroke="#7a8090" stroke-width="1.5"/>
          <line x1="108" y1="80" x2="130" y2="80" stroke="#7a8090" stroke-width="1.5"/>
        </g>
        <!-- Centre hub -->
        <circle cx="80" cy="80" r="20" fill="#0d0d0d" stroke="#c8cdd4" stroke-width="2"/>
        <circle cx="80" cy="80" r="10" fill="#111" stroke="#00ff41" stroke-width="1.5"/>
        <!-- Pointer -->
        <polygon points="80,10 77,20 83,20" fill="#00ff41" filter="url(#gateGlow)"/>
        <!-- Handle -->
        <rect x="100" y="75" width="22" height="10" rx="5" fill="#c8cdd4" stroke="#7a8090"/>
        <circle cx="122" cy="80" r="4" fill="#7a8090"/>
        <defs>
          <filter id="gateGlow">
            <feGaussianBlur in="SourceGraphic" stdDeviation="2" result="b"/>
            <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>
      </svg>
    </div>

    <!-- Combination drums -->
    <div id="gate-combo" aria-label="Combination lock" aria-live="polite">
      <div class="gate-drum" id="drum-0"><span>—</span></div>
      <div class="gate-drum" id="drum-1"><span>—</span></div>
      <div class="gate-drum" id="drum-2"><span>—</span></div>
    </div>

    <p id="gate-status">VAULT SECURED</p>

    <button id="gate-btn" onclick="crackTheVault()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      CRACK THE SAFE
    </button>

    <p id="gate-hint">Members only. Click to unlock.</p>

  </div>
</div>

<style>
#vault-gate {
  position: fixed;
  inset: 0;
  z-index: 4000;
  display: flex;
  align-items: center;
  justify-content: center;
}

#vault-gate__bg {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.92);
  backdrop-filter: blur(6px);
}

#vault-gate__panel {
  position: relative;
  z-index: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
  padding: 20px;
}

/* Vault icon */
#gate-icon {
  width: 160px; height: 160px;
  filter: drop-shadow(0 0 20px rgba(0,255,65,0.4));
}

#gate-icon svg { width: 100%; height: 100%; }

#gate-spokes { transform-origin: 80px 80px; }

/* Combination drums */
#gate-combo {
  display: flex;
  gap: 8px;
}

.gate-drum {
  width: 68px; height: 88px;
  background: var(--clr-panel);
  border: 1px solid var(--clr-border);
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 2.4rem;
  font-weight: 900;
  color: var(--clr-silver-dim);
  overflow: hidden;
  position: relative;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.gate-drum.spinning {
  border-color: var(--clr-green);
  box-shadow: 0 0 12px rgba(0,255,65,0.3), inset 0 0 20px rgba(0,255,65,0.05);
}

.gate-drum.locked {
  color: var(--clr-green);
  border-color: var(--clr-green);
  box-shadow: var(--glow-green);
  text-shadow: var(--glow-green);
}

/* Drum scan line */
.gate-drum::after {
  content: '';
  position: absolute;
  left: 0; right: 0;
  height: 2px;
  background: rgba(0,255,65,0.25);
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
}

/* Status */
#gate-status {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--clr-silver-dim);
  letter-spacing: 0.35em;
  text-transform: uppercase;
  min-height: 1.2em;
  transition: color 0.3s;
}

#gate-status.active { color: var(--clr-green); text-shadow: var(--glow-green); }

/* Crack button */
#gate-btn {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--clr-black);
  background: var(--clr-green);
  border: none;
  padding: 14px 36px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: none;
  transition: all 0.3s ease;
  box-shadow: var(--glow-green);
}

#gate-btn:hover { background: #00e838; transform: translateY(-2px); }
#gate-btn:disabled { opacity: 0.5; pointer-events: none; }

#gate-hint {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--clr-silver-dim);
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

/* Gate exit animation */
#vault-gate.unlocking {
  pointer-events: none;
}

#vault-gate.unlocking #vault-gate__bg {
  animation: gateFade 0.8s 0.4s ease-out forwards;
}

#vault-gate.unlocking #vault-gate__panel {
  animation: gateSlideUp 0.7s 0.3s ease-out forwards;
}

@keyframes gateFade {
  to { opacity: 0; }
}

@keyframes gateSlideUp {
  to { opacity: 0; transform: translateY(-30px) scale(0.95); }
}
</style>

<script>
(function () {
  const STORAGE_KEY = 'vault_club_unlocked_v1';

  // Skip gate if already unlocked this session
  if (sessionStorage.getItem(STORAGE_KEY)) {
    document.getElementById('vault-gate').style.display = 'none';
    return;
  }

  const COMBOS = ['7','4','2', '3','8','1', '9','2','6', '5','0','7'];
  const FINAL  = [COMBOS[0], COMBOS[1], COMBOS[2]];
  const STATUS_MSGS = [
    'READING TUMBLERS...',
    'ALIGNING PINS...',
    'BREAKING CIPHER...',
    'COMBINATION LOCKED...',
    'VAULT UNLOCKED',
  ];

  window.crackTheVault = function () {
    const btn    = document.getElementById('gate-btn');
    const status = document.getElementById('gate-status');
    const gate   = document.getElementById('vault-gate');
    const icon   = document.getElementById('gate-spokes');
    const drums  = [
      document.getElementById('drum-0'),
      document.getElementById('drum-1'),
      document.getElementById('drum-2'),
    ];

    btn.disabled = true;
    document.getElementById('gate-hint').style.opacity = '0';

    // Spin the vault dial graphic
    let deg = 0, speed = 18;
    const dialSpin = setInterval(() => {
      deg   += speed;
      speed  = Math.min(speed + 0.8, 40);
      icon.style.transform = 'rotate(' + deg + 'deg)';
    }, 16);

    // Status cycling
    let sIdx = 0;
    const statusTimer = setInterval(() => {
      status.textContent = STATUS_MSGS[sIdx % STATUS_MSGS.length];
      status.classList.add('active');
      sIdx++;
    }, 500);

    // Spin all drums immediately
    drums.forEach(d => {
      d.classList.add('spinning');
      d.querySelector('span').textContent = Math.floor(Math.random() * 10);
    });

    // Fast spin interval
    const spinInterval = setInterval(() => {
      drums.forEach(d => {
        if (!d.classList.contains('locked')) {
          d.querySelector('span').textContent = Math.floor(Math.random() * 10);
        }
      });
    }, 60);

    // Lock each drum sequentially
    function lockDrum(idx, delay) {
      setTimeout(() => {
        clearInterval(spinInterval); // will be re-created for remaining drums
        const remaining = setInterval(() => {
          drums.forEach((d, i) => {
            if (i > idx && !d.classList.contains('locked')) {
              d.querySelector('span').textContent = Math.floor(Math.random() * 10);
            }
          });
        }, 60);

        drums[idx].classList.remove('spinning');
        drums[idx].classList.add('locked');
        drums[idx].querySelector('span').textContent = FINAL[idx];

        if (idx === drums.length - 1) {
          clearInterval(remaining);
          clearInterval(statusTimer);
          clearInterval(dialSpin);

          setTimeout(() => {
            status.textContent = 'VAULT UNLOCKED';
            status.style.color = 'var(--clr-green)';
            status.style.textShadow = 'var(--glow-green)';
            status.style.fontSize  = '0.85rem';
            status.style.letterSpacing = '0.4em';

            setTimeout(() => {
              gate.classList.add('unlocking');
              sessionStorage.setItem(STORAGE_KEY, '1');
              setTimeout(() => {
                gate.style.display = 'none';
                window.scrollTo({ top: 0, behavior: 'smooth' });
              }, 1200);
            }, 700);
          }, 200);
        }
      }, delay);
    }

    lockDrum(0, 1600);
    lockDrum(1, 2300);
    lockDrum(2, 3000);
  };
})();
</script>
{%- endif -%}


<!-- ============================================================
     COLLECTION BODY — filters + products
============================================================ -->
<div class="section">
  <div class="page-width">

    <div class="collection-layout">

      <!-- Filter Sidebar -->
      <aside class="filter-panel" aria-label="Collection filters">
        <div class="filter-panel__title">FILTERS</div>

        {%- for filter in collection.filters -%}
          <div class="filter-group">
            <p class="filter-group__label">{{ filter.label | upcase }}</p>

            {%- case filter.type -%}
              {%- when 'list' -%}
                {%- for value in filter.values -%}
                  <div class="filter-option">
                    <input type="checkbox"
                           id="filter-{{ filter.param_name }}-{{ forloop.index }}"
                           name="{{ filter.param_name }}"
                           value="{{ value.value }}"
                           {% if value.active %}checked{% endif %}
                           {% if value.count == 0 and value.active == false %}disabled{% endif %}
                           onchange="this.form.submit()">
                    <label for="filter-{{ filter.param_name }}-{{ forloop.index }}">
                      {{ value.label }} ({{ value.count }})
                    </label>
                  </div>
                {%- endfor -%}

              {%- when 'price_range' -%}
                <div style="display:flex;gap:8px;align-items:center;">
                  <input type="number"
                         name="{{ filter.min_value.param_name }}"
                         value="{{ filter.min_value.value | money_without_currency | remove: ',' }}"
                         min="0"
                         max="{{ filter.range_max | money_without_currency | remove: ',' }}"
                         style="background:var(--clr-dark);border:1px solid var(--clr-border);color:var(--clr-white);font-family:var(--font-mono);font-size:0.65rem;padding:6px 10px;width:80px;border-radius:var(--radius);outline:none;"
                         placeholder="MIN"
                         aria-label="Minimum price">
                  <span style="color:var(--clr-silver-dim);font-family:var(--font-mono);font-size:0.65rem;">—</span>
                  <input type="number"
                         name="{{ filter.max_value.param_name }}"
                         value="{{ filter.max_value.value | money_without_currency | remove: ',' }}"
                         min="0"
                         max="{{ filter.range_max | money_without_currency | remove: ',' }}"
                         style="background:var(--clr-dark);border:1px solid var(--clr-border);color:var(--clr-white);font-family:var(--font-mono);font-size:0.65rem;padding:6px 10px;width:80px;border-radius:var(--radius);outline:none;"
                         placeholder="MAX"
                         aria-label="Maximum price">
                </div>
            {%- endcase -%}
          </div>
        {%- endfor -%}

        {%- if collection.filters.size > 0 -%}
          <a href="{{ collection.url }}" class="btn btn--ghost" style="width:100%;justify-content:center;font-size:0.65rem;padding:10px 16px;margin-top:12px;">
            CLEAR FILTERS
          </a>
        {%- endif -%}
      </aside>

      <!-- Products -->
      <div>
        <!-- Toolbar -->
        <div class="collection-toolbar">
          <p class="collection-count">
            <span>{{ collection.products_count }}</span> ITEMS SECURED
          </p>

          <select class="sort-select" aria-label="Sort products"
                  onchange="window.location = '{{ collection.url }}?sort_by=' + this.value">
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            <option value="manual"             {% if sort_by == 'manual' %}selected{% endif %}>FEATURED</option>
            <option value="best-selling"       {% if sort_by == 'best-selling' %}selected{% endif %}>BEST SELLING</option>
            <option value="title-ascending"    {% if sort_by == 'title-ascending' %}selected{% endif %}>A–Z</option>
            <option value="title-descending"   {% if sort_by == 'title-descending' %}selected{% endif %}>Z–A</option>
            <option value="price-ascending"    {% if sort_by == 'price-ascending' %}selected{% endif %}>PRICE: LOW</option>
            <option value="price-descending"   {% if sort_by == 'price-descending' %}selected{% endif %}>PRICE: HIGH</option>
            <option value="created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>NEWEST</option>
          </select>
        </div>

        {%- paginate collection.products by 24 -%}
          {%- if collection.products.size > 0 -%}
            <div class="product-grid">
              {%- for product in collection.products -%}
                {%- render 'product-card', product: product, show_vendor: true -%}
              {%- endfor -%}
            </div>

            {%- if paginate.pages > 1 -%}
              <nav style="margin-top:48px;display:flex;align-items:center;justify-content:center;gap:8px;" aria-label="Pagination">
                {%- if paginate.previous -%}
                  <a href="{{ paginate.previous.url }}" class="btn btn--outline" style="padding:10px 16px;font-size:0.65rem;">← PREV</a>
                {%- endif -%}
                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}" class="btn btn--outline" style="padding:10px 16px;font-size:0.65rem;">{{ part.title }}</a>
                  {%- else -%}
                    <span style="font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-green);padding:10px 16px;border:1px solid var(--clr-green);">{{ part.title }}</span>
                  {%- endif -%}
                {%- endfor -%}
                {%- if paginate.next -%}
                  <a href="{{ paginate.next.url }}" class="btn btn--outline" style="padding:10px 16px;font-size:0.65rem;">NEXT →</a>
                {%- endif -%}
              </nav>
            {%- endif -%}

          {%- else -%}
            <div style="text-align:center;padding:80px 0;">
              <p style="font-family:var(--font-display);font-size:1.2rem;color:var(--clr-silver-dim);letter-spacing:0.2em;">VAULT EMPTY</p>
              <p style="font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-silver-dim);margin-top:12px;">No items match your criteria.</p>
              <a href="{{ collection.url }}" class="btn btn--outline" style="margin-top:24px;">CLEAR FILTERS</a>
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>

    </div>
  </div>
</div>
