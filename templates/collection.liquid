{% layout 'theme' %}

<!-- Collection banner -->
<div class="collection-banner">
  {%- if collection.image -%}
    <div class="collection-banner__bg"
         style="background-image: url('{{ collection.image | img_url: '2000x' }}');"
         aria-hidden="true">
    </div>
  {%- else -%}
    <div class="collection-banner__bg"
         style="background: linear-gradient(135deg, #0d0d0d 0%, #111111 50%, #000000 100%);"
         aria-hidden="true">
    </div>
  {%- endif -%}

  <div class="collection-banner__content page-width">
    <p class="section-eyebrow">VAULT CATEGORY</p>
    <h1 class="section-title" data-scramble-scroll>{{ collection.title | upcase }}</h1>
    {%- if collection.description != blank -%}
      <p class="section-desc" style="max-width:560px;margin:16px auto 0;">
        {{ collection.description | strip_html }}
      </p>
    {%- endif -%}
  </div>
</div>

<!-- Collection body -->
<div class="section">
  <div class="page-width">

    <div class="collection-layout">

      <!-- Filter Sidebar -->
      <aside class="filter-panel" aria-label="Collection filters">
        <div class="filter-panel__title">FILTERS</div>

        {%- for filter in collection.filters -%}
          <div class="filter-group">
            <p class="filter-group__label">{{ filter.label | upcase }}</p>

            {%- case filter.type -%}
              {%- when 'list' -%}
                {%- for value in filter.values -%}
                  <div class="filter-option">
                    <input type="checkbox"
                           id="filter-{{ filter.param_name }}-{{ forloop.index }}"
                           name="{{ filter.param_name }}"
                           value="{{ value.value }}"
                           {% if value.active %}checked{% endif %}
                           {% if value.count == 0 and value.active == false %}disabled{% endif %}
                           onchange="this.form.submit()">
                    <label for="filter-{{ filter.param_name }}-{{ forloop.index }}">
                      {{ value.label }} ({{ value.count }})
                    </label>
                  </div>
                {%- endfor -%}

              {%- when 'price_range' -%}
                <div style="display:flex;gap:8px;align-items:center;">
                  <input type="number"
                         name="{{ filter.min_value.param_name }}"
                         value="{{ filter.min_value.value | money_without_currency | remove: ',' }}"
                         min="0"
                         max="{{ filter.range_max | money_without_currency | remove: ',' }}"
                         style="background:var(--clr-dark);border:1px solid var(--clr-border);color:var(--clr-white);font-family:var(--font-mono);font-size:0.65rem;padding:6px 10px;width:80px;border-radius:var(--radius);outline:none;"
                         placeholder="MIN"
                         aria-label="Minimum price">
                  <span style="color:var(--clr-silver-dim);font-family:var(--font-mono);font-size:0.65rem;">—</span>
                  <input type="number"
                         name="{{ filter.max_value.param_name }}"
                         value="{{ filter.max_value.value | money_without_currency | remove: ',' }}"
                         min="0"
                         max="{{ filter.range_max | money_without_currency | remove: ',' }}"
                         style="background:var(--clr-dark);border:1px solid var(--clr-border);color:var(--clr-white);font-family:var(--font-mono);font-size:0.65rem;padding:6px 10px;width:80px;border-radius:var(--radius);outline:none;"
                         placeholder="MAX"
                         aria-label="Maximum price">
                </div>
            {%- endcase -%}
          </div>
        {%- endfor -%}

        {%- if collection.filters.size > 0 -%}
          <a href="{{ collection.url }}" class="btn btn--ghost" style="width:100%;justify-content:center;font-size:0.65rem;padding:10px 16px;margin-top:12px;">
            CLEAR FILTERS
          </a>
        {%- endif -%}
      </aside>

      <!-- Products -->
      <div>
        <!-- Toolbar -->
        <div class="collection-toolbar">
          <p class="collection-count">
            <span>{{ collection.products_count }}</span> ITEMS SECURED
          </p>

          <select class="sort-select" aria-label="Sort products"
                  onchange="window.location = '{{ collection.url }}?sort_by=' + this.value">
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            <option value="manual"           {% if sort_by == 'manual' %}selected{% endif %}>FEATURED</option>
            <option value="best-selling"     {% if sort_by == 'best-selling' %}selected{% endif %}>BEST SELLING</option>
            <option value="title-ascending"  {% if sort_by == 'title-ascending' %}selected{% endif %}>A–Z</option>
            <option value="title-descending" {% if sort_by == 'title-descending' %}selected{% endif %}>Z–A</option>
            <option value="price-ascending"  {% if sort_by == 'price-ascending' %}selected{% endif %}>PRICE: LOW</option>
            <option value="price-descending" {% if sort_by == 'price-descending' %}selected{% endif %}>PRICE: HIGH</option>
            <option value="created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>NEWEST</option>
          </select>
        </div>

        {%- if collection.products.size > 0 -%}
          <div class="product-grid">
            {%- for product in collection.products -%}
              {%- render 'product-card', product: product, show_vendor: true -%}
            {%- endfor -%}
          </div>

          <!-- Pagination -->
          {%- if paginate.pages > 1 -%}
            <nav class="pagination" aria-label="Pagination" style="margin-top:48px;display:flex;align-items:center;justify-content:center;gap:8px;">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="btn btn--outline" style="padding:10px 16px;font-size:0.65rem;">PREV</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}"
                     class="btn btn--outline"
                     style="padding:10px 16px;font-size:0.65rem;">
                    {{ part.title }}
                  </a>
                {%- else -%}
                  <span style="font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-green);padding:10px 16px;border:1px solid var(--clr-green);">
                    {{ part.title }}
                  </span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="btn btn--outline" style="padding:10px 16px;font-size:0.65rem;">NEXT</a>
              {%- endif -%}
            </nav>
          {%- endif -%}

        {%- else -%}
          <div style="text-align:center;padding:80px 0;">
            <p style="font-family:var(--font-display);font-size:1.2rem;color:var(--clr-silver-dim);letter-spacing:0.2em;">VAULT EMPTY</p>
            <p style="font-family:var(--font-mono);font-size:0.7rem;color:var(--clr-silver-dim);margin-top:12px;">No items match your criteria. Clear filters to access more content.</p>
            <a href="{{ collection.url }}" class="btn btn--outline" style="margin-top:24px;">CLEAR FILTERS</a>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>
