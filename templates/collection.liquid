/* ── Mobile gate ── */
@media (max-width: 600px) {
  #vault-gate {
    align-items: flex-start;
    overflow-y: auto;
    padding-top: env(safe-area-inset-top, 0px);
  }

  #vault-gate__panel {
    gap: 16px;
    padding: 32px 20px 40px;
    width: 100%;
    min-height: 100svh;
    justify-content: center;
  }

  #gate-icon {
    width: 100px;
    height: 100px;
  }

  #gate-combo {
    gap: 6px;
  }

  .gate-drum {
    width: 52px;
    height: 68px;
    font-size: 1.8rem;
  }

  #gate-status {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
  }

  #gate-btn {
    width: 100%;
    justify-content: center;
    padding: 14px 24px;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
  }

  #gate-password-wrap {
    width: 100%;
    max-width: 100%;
  }

  #gate-password-input {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    padding: 12px 16px;
  }

  #gate-hint {
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    justify-content: center;
  }

  #gate-discord-link {
    font-size: 0.52rem;
    letter-spacing: 0.12em;
    text-align: center;
    justify-content: center;
  }
}
</style>

<script>
(function () {
  /* ── Auth storage key ───────────────────────────────────────── */
  var AUTH_KEY = 'wrc_club_auth_v1';

  /* ── Password check ─────────────────────────────────────────
     Stored as btoa('CULTIVATE') so plaintext is not in source.
     To change the password: replace PASS_HASH with btoa(NEW_PASSWORD)
  ──────────────────────────────────────────────────────────── */
  var PASS_HASH = 'Q1VMVElWQVRF';   /* = btoa('CULTIVATE') */

  /* ── Skip gate if already authenticated ─────────────────── */
  (function checkAuth() {
    try {
      if (localStorage.getItem(AUTH_KEY) === '1') {
        var gate = document.getElementById('vault-gate');
        if (gate) gate.style.display = 'none';
      }
    } catch(e) {}
  })();

  /* ── Unlock animation ───────────────────────────────────── */
  var FINAL       = ['7','4','2'];
  var STATUS_MSGS = [
    'READING TUMBLERS...',
    'ALIGNING PINS...',
    'BREAKING CIPHER...',
    'COMBINATION LOCKED...',
    'ACCESS GRANTED',
  ];

  function playUnlockAnimation() {
    var btn    = document.getElementById('gate-btn');
    var status = document.getElementById('gate-status');
    var gate   = document.getElementById('vault-gate');
    var icon   = document.getElementById('gate-spokes');
    var pwWrap = document.getElementById('gate-password-wrap');
    var hint   = document.getElementById('gate-hint');
    var discord= document.getElementById('gate-discord-link');
    var drums  = [
      document.getElementById('drum-0'),
      document.getElementById('drum-1'),
      document.getElementById('drum-2'),
    ];

    /* Fade out form elements */
    if (pwWrap)  { pwWrap.style.transition  = 'opacity 0.3s'; pwWrap.style.opacity  = '0'; }
    if (hint)    { hint.style.transition    = 'opacity 0.3s'; hint.style.opacity    = '0'; }
    if (discord) { discord.style.transition = 'opacity 0.3s'; discord.style.opacity = '0'; }

    /* Spin vault dial */
    var deg = 0, speed = 18;
    var dialSpin = setInterval(function() {
      deg   += speed;
      speed  = Math.min(speed + 0.8, 40);
      icon.style.transform = 'rotate(' + deg + 'deg)';
    }, 16);

    /* Status cycling */
    var sIdx = 0;
    var statusTimer = setInterval(function() {
      status.textContent = STATUS_MSGS[sIdx % STATUS_MSGS.length];
      status.classList.add('active');
      sIdx++;
    }, 500);

    /* Spin all drums */
    drums.forEach(function(d) {
      d.classList.add('spinning');
      d.querySelector('span').textContent = Math.floor(Math.random() * 10);
    });

    var spinInterval = setInterval(function() {
      drums.forEach(function(d) {
        if (!d.classList.contains('locked')) {
          d.querySelector('span').textContent = Math.floor(Math.random() * 10);
        }
      });
    }, 60);

    /* Lock each drum sequentially */
    function lockDrum(idx, delay) {
      setTimeout(function() {
        clearInterval(spinInterval);
        var remaining = setInterval(function() {
          drums.forEach(function(d, i) {
            if (i > idx && !d.classList.contains('locked')) {
              d.querySelector('span').textContent = Math.floor(Math.random() * 10);
            }
          });
        }, 60);

        drums[idx].classList.remove('spinning');
        drums[idx].classList.add('locked');
        drums[idx].querySelector('span').textContent = FINAL[idx];

        if (idx === drums.length - 1) {
          clearInterval(remaining);
          clearInterval(statusTimer);
          clearInterval(dialSpin);

          setTimeout(function() {
            status.textContent       = 'ACCESS GRANTED';
            status.style.color       = 'var(--clr-green)';
            status.style.textShadow  = 'var(--glow-green)';
            status.style.fontSize    = '0.85rem';
            status.style.letterSpacing = '0.4em';

            setTimeout(function() {
              gate.classList.add('unlocking');
              setTimeout(function() {
                gate.style.display = 'none';
                window.scrollTo({ top: 0, behavior: 'smooth' });
              }, 1200);
            }, 800);
          }, 200);
        }
      }, delay);
    }

    lockDrum(0, 1600);
    lockDrum(1, 2300);
    lockDrum(2, 3000);
  }

  /* ── Access denied feedback ─────────────────────────────── */
  function showDenied() {
    var input  = document.getElementById('gate-password-input');
    var error  = document.getElementById('gate-input-error');
    var status = document.getElementById('gate-status');
    var btn    = document.getElementById('gate-btn');

    status.textContent      = 'ACCESS DENIED — INVALID CODE';
    status.style.color      = '#ff4444';
    status.style.textShadow = '0 0 12px rgba(255,50,50,0.5)';

    if (input) {
      input.classList.add('denied');
      input.value = '';
      setTimeout(function() { input.focus(); }, 50);
    }
    if (error) error.textContent = '⛔ INCORRECT — CHECK YOUR DISCORD CODE';

    setTimeout(function() {
      if (input) input.classList.remove('denied');
      if (error) error.textContent = '';
      status.textContent      = 'VAULT SECURED';
      status.style.color      = '';
      status.style.textShadow = '';
      btn.disabled            = false;
    }, 2000);
  }

  /* ── Main entry point (called by button onclick) ─────────── */
  window.crackTheVault = function() {
    var input   = document.getElementById('gate-password-input');
    var entered = input ? input.value.trim().toUpperCase() : '';
    var btn     = document.getElementById('gate-btn');

    if (!entered) {
      if (input) { input.focus(); input.classList.add('denied'); setTimeout(function(){ input.classList.remove('denied'); }, 500); }
      return;
    }

    btn.disabled = true;

    /* Compare against stored hash */
    var match = false;
    try { match = (typeof btoa === 'function') && (btoa(entered) === PASS_HASH); } catch(e) {}

    if (match) {
      try { localStorage.setItem(AUTH_KEY, '1'); } catch(e) {}
      playUnlockAnimation();
    } else {
      showDenied();
    }
  };

  /* ── Enter key support ───────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function() {
    var input = document.getElementById('gate-password-input');
    if (input) {
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') window.crackTheVault();
      });
      /* Auto-focus the input if gate is visible */
      try {
        if (localStorage.getItem(AUTH_KEY) !== '1') {
          setTimeout(function() { input.focus(); }, 600);
        }
      } catch(e) {}
    }
  });
})();
</script>
{%- endif -%}


