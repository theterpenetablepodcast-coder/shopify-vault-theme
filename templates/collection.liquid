{% layout 'theme' %}

{%- assign is_club      = false -%}
{%- assign is_uniform   = false -%}
{%- assign is_drops     = false -%}
{%- assign is_hub       = false -%}

{%- assign is_wrc       = false -%}
{%- assign is_roots     = false -%}
{%- assign is_movement  = false -%}
{%- assign is_signature = false -%}
{%- assign is_kit_carry = false -%}
{%- assign is_wrc_hub   = false -%}

{%- comment -%} ── Cultivators Club flags ── {%- endcomment -%}
{%- if collection.handle contains 'cultivator' -%}
  {%- assign is_club = true -%}
{%- endif -%}
{%- if collection.handle == 'the-uniform' -%}
  {%- assign is_club    = true -%}
  {%- assign is_uniform = true -%}
{%- endif -%}
{%- if collection.handle == 'the-drops' -%}
  {%- assign is_club  = true -%}
  {%- assign is_drops = true -%}
{%- endif -%}
{%- if is_club and is_uniform == false and is_drops == false -%}
  {%- assign is_hub = true -%}
{%- endif -%}

{%- comment -%} ── WRC Clothing flags ── {%- endcomment -%}
{%- if collection.handle == 'merch' -%}
  {%- assign is_wrc = true -%}
{%- endif -%}
{%- if collection.handle == 'the-roots' -%}
  {%- assign is_wrc   = true -%}
  {%- assign is_roots = true -%}
{%- endif -%}
{%- if collection.handle == 'the-movement' -%}
  {%- assign is_wrc      = true -%}
  {%- assign is_movement = true -%}
{%- endif -%}
{%- if collection.handle == 'the-wrc-signature' -%}
  {%- assign is_wrc       = true -%}
  {%- assign is_signature = true -%}
{%- endif -%}
{%- if collection.handle == 'the-kit-and-carry' -%}
  {%- assign is_wrc       = true -%}
  {%- assign is_kit_carry = true -%}
{%- endif -%}
{%- if is_wrc and is_roots == false and is_movement == false and is_signature == false and is_kit_carry == false -%}
  {%- assign is_wrc_hub = true -%}
{%- endif -%}

<!-- ============================================================
     COLLECTION HERO — image fills top, text sits cleanly below
============================================================ -->

{%- if collection.image -%}
  <div style="width:100%;aspect-ratio:21/7;overflow:hidden;position:relative;background:var(--clr-black);">
    <img src="{{ collection.image | img_url: '2000x' }}"
         alt="{{ collection.title | escape }}"
         style="width:100%;height:100%;object-fit:cover;filter:brightness(0.7);"
         loading="eager">
    <!-- bottom fade so it bleeds cleanly into the text panel below -->
    <div style="position:absolute;bottom:0;left:0;right:0;height:50%;background:linear-gradient(to bottom,transparent,var(--clr-black));"></div>
    {%- if is_club -%}
      <!-- CLASSIFIED watermark on the image -->
      <div style="position:absolute;top:20px;left:50%;transform:translateX(-50%);font-family:var(--font-mono);font-size:0.6rem;color:rgba(0,255,65,0.6);letter-spacing:0.5em;text-transform:uppercase;white-space:nowrap;">
        ⬡ RESTRICTED ACCESS ⬡
      </div>
    {%- endif -%}
  </div>
{%- endif -%}

<!-- Text panel — always below the image -->
<div style="background:var(--clr-black);padding:{% if collection.image %}36px{% else %}72px{% endif %} 0 40px;border-bottom:1px solid var(--clr-border);text-align:center;">
  <div class="page-width">
    <p class="section-eyebrow">{% if is_club %}⬡ EXCLUSIVE ACCESS{% elsif is_wrc %}◈ WRC CLOTHING{% else %}VAULT CATEGORY{% endif %}</p>
    <h1 class="section-title" data-scramble-scroll>{{ collection.title | upcase }}</h1>
    {%- if collection.description != blank -%}
      <p style="font-family:var(--font-mono);font-size:0.8rem;color:var(--clr-silver-dim);letter-spacing:0.06em;max-width:640px;margin:16px auto 0;line-height:1.9;">
        {{ collection.description | strip_html }}
      </p>
    {%- endif -%}
  </div>
</div>


<!-- ============================================================
     VAULT-CRACK GATE — Cultivators Club only
============================================================ -->
{%- if is_club -%}
<div id="vault-gate">

  <!-- Dim overlay behind gate content -->
  <div id="vault-gate__bg"></div>

  <div id="vault-gate__panel">

    <!-- Spinning vault icon -->
    <div id="gate-icon" aria-hidden="true">
      <svg viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="80" cy="80" r="72" stroke="#1e1e1e" stroke-width="4"/>
        <!-- Tick marks -->
        {%- for i in (0..39) -%}
          {%- assign a = i | times: 9 -%}
          {%- assign mod5 = i | modulo: 5 -%}
          {%- assign mod10 = i | modulo: 10 -%}
          {%- if mod10 == 0 -%}
            <line x1="80" y1="10" x2="80" y2="22" stroke="#00ff41" stroke-width="2.5" transform="rotate({{ a }},80,80)"/>
          {%- elsif mod5 == 0 -%}
            <line x1="80" y1="11" x2="80" y2="21" stroke="#c8cdd4" stroke-width="1.5" transform="rotate({{ a }},80,80)"/>
          {%- else -%}
            <line x1="80" y1="13" x2="80" y2="19" stroke="#1e1e1e" stroke-width="1" transform="rotate({{ a }},80,80)"/>
          {%- endif -%}
        {%- endfor -%}
        <!-- Dial ring -->
        <circle id="gate-dial-ring" cx="80" cy="80" r="55" stroke="#00ff41" stroke-width="1.5" stroke-dasharray="6 4"/>
        <!-- Spokes -->
        <g id="gate-spokes">
          <line x1="80" y1="30" x2="80" y2="52" stroke="#7a8090" stroke-width="1.5"/>
          <line x1="80" y1="108" x2="80" y2="130" stroke="#7a8090" stroke-width="1.5"/>
          <line x1="30" y1="80" x2="52" y2="80" stroke="#7a8090" stroke-width="1.5"/>
          <line x1="108" y1="80" x2="130" y2="80" stroke="#7a8090" stroke-width="1.5"/>
        </g>
        <!-- Centre hub -->
        <circle cx="80" cy="80" r="20" fill="#0d0d0d" stroke="#c8cdd4" stroke-width="2"/>
        <circle cx="80" cy="80" r="10" fill="#111" stroke="#00ff41" stroke-width="1.5"/>
        <!-- Pointer -->
        <polygon points="80,10 77,20 83,20" fill="#00ff41" filter="url(#gateGlow)"/>
        <!-- Handle -->
        <rect x="100" y="75" width="22" height="10" rx="5" fill="#c8cdd4" stroke="#7a8090"/>
        <circle cx="122" cy="80" r="4" fill="#7a8090"/>
        <defs>
          <filter id="gateGlow">
            <feGaussianBlur in="SourceGraphic" stdDeviation="2" result="b"/>
            <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>
      </svg>
    </div>

    <!-- Combination drums -->
    <div id="gate-combo" aria-label="Combination lock" aria-live="polite">
      <div class="gate-drum" id="drum-0"><span>—</span></div>
      <div class="gate-drum" id="drum-1"><span>—</span></div>
      <div class="gate-drum" id="drum-2"><span>—</span></div>
    </div>

    <p id="gate-status">VAULT SECURED</p>

    <!-- Password entry -->
    <div id="gate-password-wrap">
      <input type="password"
             id="gate-password-input"
             placeholder="ENTER ACCESS CODE"
             maxlength="32"
             autocomplete="off"
             spellcheck="false"
             aria-label="Cultivators Club access code">
      <p id="gate-input-error" aria-live="polite"></p>
    </div>

    <button id="gate-btn" onclick="crackTheVault()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="3" y="11" width="18" height="11" rx="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      UNLOCK THE VAULT
    </button>

    <!-- Discord invite -->
    <div id="gate-hint">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0;opacity:0.6;">
        <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.033.055a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
      </svg>
      <span>DISCORD MEMBERS ONLY &mdash; ACCESS CODE DISTRIBUTED EXCLUSIVELY VIA WRC DISCORD</span>
    </div>
    <a href="https://discord.gg/mE8z5Defdc"
       target="_blank"
       rel="noopener noreferrer"
       id="gate-discord-link">
      JOIN THE DISCORD TO OBTAIN YOUR CODE
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

  </div>
</div>

<style>
#vault-gate {
  position: fixed;
  inset: 0;
  z-index: 4000;
  display: flex;
  align-items: center;
  justify-content: center;
}

#vault-gate__bg {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.92);
  backdrop-filter: blur(6px);
}

#vault-gate__panel {
  position: relative;
  z-index: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
  padding: 20px;
}

/* Vault icon */
#gate-icon {
  width: 160px; height: 160px;
  filter: drop-shadow(0 0 20px rgba(0,255,65,0.4));
}

#gate-icon svg { width: 100%; height: 100%; }

#gate-spokes { transform-origin: 80px 80px; }

/* Combination drums */
#gate-combo {
  display: flex;
  gap: 8px;
}

.gate-drum {
  width: 68px; height: 88px;
  background: var(--clr-panel);
  border: 1px solid var(--clr-border);
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 2.4rem;
  font-weight: 900;
  color: var(--clr-silver-dim);
  overflow: hidden;
  position: relative;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.gate-drum.spinning {
  border-color: var(--clr-green);
  box-shadow: 0 0 12px rgba(0,255,65,0.3), inset 0 0 20px rgba(0,255,65,0.05);
}

.gate-drum.locked {
  color: var(--clr-green);
  border-color: var(--clr-green);
  box-shadow: var(--glow-green);
  text-shadow: var(--glow-green);
}

/* Drum scan line */
.gate-drum::after {
  content: '';
  position: absolute;
  left: 0; right: 0;
  height: 2px;
  background: rgba(0,255,65,0.25);
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
}

/* Status */
#gate-status {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--clr-silver-dim);
  letter-spacing: 0.35em;
  text-transform: uppercase;
  min-height: 1.2em;
  transition: color 0.3s;
}

#gate-status.active { color: var(--clr-green); text-shadow: var(--glow-green); }

/* Crack button */
#gate-btn {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--clr-black);
  background: var(--clr-green);
  border: none;
  padding: 14px 36px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: none;
  transition: all 0.3s ease;
  box-shadow: var(--glow-green);
}

#gate-btn:hover { background: #00e838; transform: translateY(-2px); }
#gate-btn:disabled { opacity: 0.5; pointer-events: none; }

/* Password input */
#gate-password-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  width: 100%;
  max-width: 320px;
}

#gate-password-input {
  width: 100%;
  background: rgba(10,14,12,0.9);
  border: 1px solid var(--clr-border);
  border-radius: 4px;
  color: var(--clr-green);
  font-family: var(--font-mono);
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.3em;
  text-align: center;
  padding: 14px 20px;
  outline: none;
  transition: border-color 0.25s, box-shadow 0.25s;
  -webkit-text-security: disc;
  caret-color: var(--clr-green);
}

#gate-password-input::placeholder {
  color: var(--clr-silver-dim);
  letter-spacing: 0.2em;
  font-size: 0.7rem;
}

#gate-password-input:focus {
  border-color: var(--clr-green);
  box-shadow: 0 0 0 1px rgba(0,255,65,0.15), 0 0 20px rgba(0,255,65,0.08);
}

#gate-password-input.denied {
  border-color: #ff3333;
  box-shadow: 0 0 0 1px rgba(255,50,50,0.2), 0 0 20px rgba(255,50,50,0.1);
  animation: inputShake 0.4s ease;
  color: #ff4444;
}

@keyframes inputShake {
  0%, 100% { transform: translateX(0); }
  20%       { transform: translateX(-6px); }
  40%       { transform: translateX(6px); }
  60%       { transform: translateX(-4px); }
  80%       { transform: translateX(4px); }
}

#gate-input-error {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  color: #ff4444;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  min-height: 1em;
}

/* Discord hint block */
#gate-hint {
  display: flex;
  align-items: flex-start;
  gap: 7px;
  font-family: var(--font-mono);
  font-size: 0.55rem;
  color: var(--clr-silver-dim);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  text-align: center;
  max-width: 340px;
  line-height: 1.7;
}

#gate-discord-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-mono);
  font-size: 0.55rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--clr-green);
  text-decoration: none;
  border-bottom: 1px solid rgba(0,255,65,0.25);
  padding-bottom: 1px;
  transition: border-color 0.2s, opacity 0.2s;
  margin-top: -8px;
}

#gate-discord-link:hover {
  border-color: var(--clr-green);
  opacity: 0.85;
}

/* Gate exit animation */
#vault-gate.unlocking {
  pointer-events: none;
}

#vault-gate.unlocking #vault-gate__bg {
  animation: gateFade 0.8s 0.4s ease-out forwards;
}

#vault-gate.unlocking #vault-gate__panel {
  animation: gateSlideUp 0.7s 0.3s ease-out forwards;
}

@keyframes gateFade {
  to { opacity: 0; }
}

@keyframes gateSlideUp {
  to { opacity: 0; transform: translateY(-30px) scale(0.95); }
}

/* ============================================================
   CLUB HUB — entry panels
   ============================================================ */
.club-hub { background: var(--clr-black); }

.club-entries {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3px;
}

/* ── Entry panel ── */
.club-entry {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  position: relative;
  overflow: hidden;
  border: 1px solid var(--clr-border);
  transition: border-color 0.35s, box-shadow 0.35s, transform 0.35s;
}

.club-entry:hover {
  border-color: var(--clr-silver-dim);
  transform: translateY(-3px);
  box-shadow: 0 12px 48px rgba(0,0,0,0.6);
}

/* Visual / image area */
.club-entry__visual {
  position: relative;
  aspect-ratio: 4 / 3;
  overflow: hidden;
  background: var(--clr-dark);
}

.club-entry__visual img {
  width: 100%; height: 100%;
  object-fit: cover;
  filter: grayscale(20%) brightness(0.8);
  transition: transform 0.6s ease, filter 0.4s ease;
}

.club-entry:hover .club-entry__visual img {
  transform: scale(1.05);
  filter: grayscale(0%) brightness(0.95);
}

.club-entry__no-img {
  width: 100%; height: 100%;
  background: repeating-linear-gradient(-45deg, #0d0d0d, #0d0d0d 10px, #000 10px, #000 20px);
}
.club-entry__no-img--gold {
  background: repeating-linear-gradient(-45deg, #0d0c09, #0d0c09 10px, #080600 10px, #080600 20px);
}

/* Overlay gradient */
.club-entry__overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 55%);
  transition: opacity 0.3s;
}
.club-entry__overlay--gold {
  background: linear-gradient(to top, rgba(10,8,0,0.75) 0%, transparent 55%);
}

/* Corner brackets */
.club-entry__bracket {
  position: absolute;
  width: 22px; height: 22px;
  border-color: rgba(200,205,212,0.45);
  border-style: solid;
  z-index: 2;
  transition: border-color 0.3s, box-shadow 0.3s;
}
.club-entry__bracket--tl { top: 12px; left: 12px; border-width: 2px 0 0 2px; }
.club-entry__bracket--br { bottom: 12px; right: 12px; border-width: 0 2px 2px 0; }
.club-entry__bracket--gold { border-color: rgba(212,168,71,0.5); }

.club-entry:hover .club-entry__bracket { border-color: rgba(200,205,212,0.9); box-shadow: 0 0 8px rgba(200,205,212,0.3); }
.club-entry:hover .club-entry__bracket--gold { border-color: #d4a847; box-shadow: 0 0 10px rgba(212,168,71,0.4); }

/* Item count badge */
.club-entry__count-badge {
  position: absolute;
  top: 12px; left: 12px;
  z-index: 3;
  background: rgba(0,0,0,0.85);
  border: 1px solid var(--clr-border);
  color: var(--clr-silver-dim);
  font-family: var(--font-display);
  font-size: 0.8rem;
  font-weight: 700;
  padding: 4px 10px;
  letter-spacing: 0.05em;
  display: flex; align-items: baseline; gap: 4px;
}
.club-entry__count-badge span { font-size: 0.45rem; letter-spacing: 0.18em; }
.club-entry__count-badge--gold { border-color: rgba(212,168,71,0.4); color: #d4a847; }

/* LIMITED badge */
.club-entry__limited {
  position: absolute;
  top: 12px; right: 12px;
  z-index: 3;
  background: rgba(0,0,0,0.88);
  border: 1px solid #d4a847;
  color: #d4a847;
  font-family: var(--font-mono);
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.25em;
  padding: 5px 10px;
  display: flex; align-items: center; gap: 7px;
  box-shadow: 0 0 12px rgba(212,168,71,0.2);
}
.club-entry__limited-dot {
  width: 5px; height: 5px;
  background: #d4a847;
  border-radius: 50%;
  box-shadow: 0 0 6px #d4a847;
  animation: goldLedPulse 1.8s ease-in-out infinite;
  flex-shrink: 0;
}

/* Body / text area */
.club-entry__body {
  padding: 22px 24px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 16px;
  border-top: 1px solid var(--clr-border);
  background: var(--clr-panel);
  flex: 1;
  transition: border-color 0.3s, background 0.3s;
}
.club-entry__body--gold {
  background: #0d0c09;
  border-top-color: rgba(212,168,71,0.15);
}
.club-entry:hover .club-entry__body { border-top-color: rgba(200,205,212,0.2); }
.club-entry:hover .club-entry__body--gold { border-top-color: rgba(212,168,71,0.3); }

.club-entry__eyebrow {
  font-family: var(--font-mono);
  font-size: 0.52rem;
  color: var(--clr-silver-dim);
  letter-spacing: 0.28em;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.club-entry__eyebrow--gold { color: rgba(212,168,71,0.7); }

.club-entry__title {
  font-family: var(--font-display);
  font-size: clamp(1.3rem, 2.5vw, 1.9rem);
  font-weight: 900;
  color: var(--clr-white);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  line-height: 1.1;
  margin-bottom: 10px;
  transition: color 0.3s;
}
.club-entry__title--gold { color: #d4a847; }
.club-entry:hover .club-entry__title { color: var(--clr-green); }
.club-entry:hover .club-entry__title--gold { color: #e0b84f; }

.club-entry__desc {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--clr-silver-dim);
  letter-spacing: 0.05em;
  line-height: 1.8;
}

.club-entry__foot { display: flex; align-items: center; justify-content: flex-end; }

.club-entry__cta {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--clr-silver);
  display: flex; align-items: center; gap: 8px;
  transition: color 0.3s, gap 0.3s;
}
.club-entry__cta--gold { color: #d4a847; }
.club-entry:hover .club-entry__cta { color: var(--clr-green); gap: 12px; }
.club-entry:hover .club-entry__cta--gold { color: #e0b84f; gap: 12px; }

/* Top accent line on hover */
.club-entry::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
