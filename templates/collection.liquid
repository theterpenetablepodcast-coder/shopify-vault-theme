/* ── Shared structural base ── */
.club-hub  { background: #080808; }
.wrc-hub   { background: var(--clr-black); }

/* ═══════════════════════════════════════════════════════════
   CLUB HUB — premium editorial panels
═══════════════════════════════════════════════════════════ */
.club-entries {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: rgba(184, 168, 130, 0.12);
}

.club-entry {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  position: relative;
  overflow: hidden;
  background: #080808;
  transition: background 0.4s;
}

.club-entry:hover {
  background: #0c0b09;
}

/* Image zone */
.club-entry__visual {
  position: relative;
  aspect-ratio: 3 / 2;
  overflow: hidden;
  background: #111009;
}

.club-entry__visual img {
  width: 100%; height: 100%;
  object-fit: cover;
  filter: brightness(0.78) saturate(0.85);
  transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              filter 0.6s ease;
}

.club-entry:hover .club-entry__visual img {
  transform: scale(1.04);
  filter: brightness(0.88) saturate(1);
}

.club-entry__no-img {
  width: 100%; height: 100%;
  background: linear-gradient(135deg, #0e0d0a 0%, #080808 100%);
}

/* Gradient scrim */
.club-entry__overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(8,8,8,0.75) 0%, rgba(8,8,8,0.1) 60%, transparent 100%);
}

/* Body */
.club-entry__body {
  padding: 32px 36px 40px;
  display: flex;
  flex-direction: column;
  gap: 0;
  flex: 1;
  border-top: 1px solid rgba(184, 168, 130, 0.12);
  transition: border-color 0.4s;
}

.club-entry:hover .club-entry__body {
  border-top-color: rgba(184, 168, 130, 0.25);
}

.club-entry__eyebrow {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.5rem;
  font-weight: 500;
  color: #A89F8C;
  letter-spacing: 0.38em;
  text-transform: uppercase;
  margin: 0 0 16px;
  opacity: 0.8;
}

.club-entry__title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2rem, 3.5vw, 2.8rem);
  font-weight: 300;
  color: #EDE8DC;
  line-height: 1.1;
  letter-spacing: 0.01em;
  margin: 0 0 18px;
  transition: color 0.3s;
}

.club-entry:hover .club-entry__title {
  color: #f5f0e8;
}

.club-entry__title em {
  font-style: italic;
}

.club-entry__desc {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.62rem;
  font-weight: 300;
  color: #A89F8C;
  letter-spacing: 0.04em;
  line-height: 1.9;
  margin: 0 0 28px;
}

.club-entry__foot {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-top: auto;
}

.club-entry__cta {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.5rem;
  font-weight: 500;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: #B8A882;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: color 0.3s, gap 0.3s;
  border-bottom: 1px solid rgba(184, 168, 130, 0.25);
  padding-bottom: 3px;
}

.club-entry:hover .club-entry__cta {
  color: #EDE8DC;
  gap: 16px;
  border-bottom-color: rgba(237, 232, 220, 0.4);
}

/* Drops variant — warm amber accent */
.club-entry--drops .club-entry__eyebrow { color: #C4A45E; }
.club-entry--drops .club-entry__cta     { color: #C4A45E; border-bottom-color: rgba(196, 164, 94, 0.25); }
.club-entry--drops:hover .club-entry__cta {
  color: #EDE8DC;
  border-bottom-color: rgba(237, 232, 220, 0.4);
}

/* ═══════════════════════════════════════════════════════════
   WRC HUB — tech grid (unchanged aesthetic)
═══════════════════════════════════════════════════════════ */
.wrc-entries {
