{% layout 'theme' %}

{%- assign is_club      = false -%}
{%- assign is_uniform   = false -%}
{%- assign is_drops     = false -%}
{%- assign is_hub       = false -%}

{%- assign is_wrc       = false -%}
{%- assign is_roots     = false -%}
{%- assign is_movement  = false -%}
{%- assign is_signature = false -%}
{%- assign is_kit_carry = false -%}
{%- assign is_wrc_hub   = false -%}

{%- comment -%} ── Cultivators Club flags ── {%- endcomment -%}
{%- if collection.handle contains 'cultivator' -%}
  {%- assign is_club = true -%}
{%- endif -%}
{%- if collection.handle == 'the-uniform' -%}
  {%- assign is_club    = true -%}
  {%- assign is_uniform = true -%}
{%- endif -%}
{%- if collection.handle == 'the-drops' -%}
  {%- assign is_club  = true -%}
  {%- assign is_drops = true -%}
{%- endif -%}
{%- if is_club and is_uniform == false and is_drops == false -%}
  {%- assign is_hub = true -%}
{%- endif -%}

{%- comment -%} ── WRC Clothing flags ── {%- endcomment -%}
{%- if collection.handle == 'merch' -%}
  {%- assign is_wrc = true -%}
{%- endif -%}
{%- if collection.handle == 'the-roots' -%}
  {%- assign is_wrc   = true -%}
  {%- assign is_roots = true -%}
{%- endif -%}
{%- if collection.handle == 'the-movement' -%}
  {%- assign is_wrc      = true -%}
  {%- assign is_movement = true -%}
{%- endif -%}
{%- if collection.handle == 'the-wrc-signature' -%}
  {%- assign is_wrc       = true -%}
  {%- assign is_signature = true -%}
{%- endif -%}
{%- if collection.handle == 'the-kit-and-carry' -%}
  {%- assign is_wrc       = true -%}
  {%- assign is_kit_carry = true -%}
{%- endif -%}
{%- if is_wrc and is_roots == false and is_movement == false and is_signature == false and is_kit_carry == false -%}
  {%- assign is_wrc_hub = true -%}
{%- endif -%}

<!-- ============================================================
     COLLECTION HERO
     - WRC sub-collections: full-width banner PNG (title is IN the image)
     - Club collections / other: hero from collection.image if set
============================================================ -->

{%- comment -%} Resolve WRC banner asset URL {%- endcomment -%}
{%- assign wrc_banner = '' -%}
{%- if is_roots     -%}{%- assign wrc_banner = 'collection-the-roots.png'          | asset_url -%}{%- endif -%}
{%- if is_movement  -%}{%- assign wrc_banner = 'collection-the-movement.png'       | asset_url -%}{%- endif -%}
{%- if is_signature -%}{%- assign wrc_banner = 'collection-the-wrc-signature.png'  | asset_url -%}{%- endif -%}
{%- if is_kit_carry -%}{%- assign wrc_banner = 'collection-the-kit-and-carry.png'  | asset_url -%}{%- endif -%}

{%- assign hero_src = '' -%}
{%- if wrc_banner != '' -%}
  {%- assign hero_src = wrc_banner -%}
{%- elsif collection.image -%}
  {%- assign hero_src = collection.image | img_url: '2000x' -%}
{%- endif -%}

{%- if hero_src != '' -%}
  <div style="width:100%;overflow:hidden;position:relative;background:var(--clr-black);
              aspect-ratio:4/1;
              ">
    <style>
      @media (max-width:768px) { .collection-hero-wrap { aspect-ratio: 16/9 !important; } }
      @media (max-width:480px) { .collection-hero-wrap { aspect-ratio: 4/3  !important; } }
    </style>
    <div class="collection-hero-wrap" style="width:100%;height:100%;aspect-ratio:4/1;overflow:hidden;position:relative;">
      <img src="{{ hero_src }}"
           alt="{{ collection.title | escape }}"
           style="width:100%;height:100%;object-fit:cover;{% if wrc_banner != '' %}object-position:center;filter:brightness(1);{% else %}filter:brightness(0.7);{% endif %}"
           loading="eager">
      <div style="position:absolute;bottom:0;left:0;right:0;height:55%;background:linear-gradient(to bottom,transparent,var(--clr-black));"></div>
      {%- if is_club -%}
        <div style="position:absolute;top:24px;left:50%;transform:translateX(-50%);font-family:'Montserrat',sans-serif;font-size:0.46rem;font-weight:500;color:rgba(237,232,220,0.55);letter-spacing:0.5em;text-transform:uppercase;white-space:nowrap;">
          The Cultivators Club
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

<!-- Text panel -->
{%- comment -%}
  For WRC sub-collections the banner already contains the title.
  Show only the eyebrow + description (no duplicate heading).
  For all other collections show the full title.
{%- endcomment -%}
{%- assign show_title = true -%}
{%- if wrc_banner != '' -%}{%- assign show_title = false -%}{%- endif -%}

<div style="background:{% if is_club %}#080808{% else %}var(--clr-black){% endif %};
            padding:{% if hero_src != '' %}clamp(18px,3vw,28px){% else %}clamp(40px,6vw,72px){% endif %} 0 clamp(20px,3vw,32px);
            border-bottom:1px solid {% if is_club %}rgba(184,168,130,0.12){% else %}var(--clr-border){% endif %};text-align:center;">
  <div class="page-width">
    {%- if is_club -%}
      <p style="font-family:'Montserrat',sans-serif;font-size:0.48rem;font-weight:500;letter-spacing:0.42em;color:#A89F8C;text-transform:uppercase;margin:0 0 16px;opacity:0.8;justify-content:center;display:flex;">The Cultivators Club</p>
    {%- else -%}
      <p class="section-eyebrow">{% if is_wrc %}◈ WRC CLOTHING{% else %}VAULT CATEGORY{% endif %}</p>
    {%- endif -%}
    {%- if show_title -%}
      {%- if is_club -%}
        <h1 style="font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(2.8rem,6vw,5rem);font-weight:300;color:#EDE8DC;letter-spacing:0.02em;line-height:1.1;text-transform:none;margin:0 0 12px;">
          {{ collection.title }}
        </h1>
      {%- else -%}
        <h1 class="section-title" data-scramble-scroll>{{ collection.title | upcase }}</h1>
      {%- endif -%}
    {%- endif -%}
    {%- if collection.description != blank -%}
      {%- if is_club -%}
        <p style="font-family:'Montserrat',sans-serif;font-size:0.65rem;font-weight:300;color:#A89F8C;letter-spacing:0.06em;max-width:520px;margin:16px auto 0;line-height:2;">
          {{ collection.description | strip_html }}
        </p>
      {%- else -%}
        <p class="section-desc" style="font-family:var(--font-mono);letter-spacing:0.06em;max-width:640px;margin:{% if show_title %}16px{% else %}8px{% endif %} auto 0;line-height:1.9;">
          {{ collection.description | strip_html }}
        </p>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>


<!-- ============================================================
     CULTIVATORS CLUB GATE — premium botanical access screen
============================================================ -->
{%- if is_club -%}
<div id="vault-gate">

  <!-- Soft dark overlay -->
  <div id="vault-gate__bg"></div>

  <div id="vault-gate__panel">

    <!-- Eyebrow mark -->
    <p class="cg-gate__eyebrow">WILDROOT CULTIVARS</p>

    <!-- Botanical illustration (blooms on unlock) -->
    <div id="gate-botanical" aria-hidden="true">
      <svg viewBox="0 0 200 230" fill="none" xmlns="http://www.w3.org/2000/svg" class="cg-botanical">
        <!-- Central stem -->
        <path class="cg-stem" d="M100 225 C100 210 98 195 100 178 C102 165 100 148 100 135"/>
        <!-- Small root tendrils -->
        <path class="cg-tendril" d="M100 210 C92 205 82 207 75 215"/>
        <path class="cg-tendril" d="M100 210 C108 205 118 207 125 215"/>
        <!-- Lower small leaves -->
        <path class="cg-leaf cg-leaf--minor" d="M100 155 C88 148 72 150 64 162 C74 152 88 153 100 155Z"/>
        <path class="cg-leaf cg-leaf--minor" d="M100 155 C112 148 128 150 136 162 C126 152 112 153 100 155Z"/>
        <!-- Middle leaves -->
        <path class="cg-leaf" d="M100 142 C82 128 58 125 40 138 C54 120 78 122 100 142Z"/>
        <path class="cg-leaf" d="M100 142 C118 128 142 125 160 138 C146 120 122 122 100 142Z"/>
        <!-- Upper-side leaves -->
        <path class="cg-leaf" d="M100 128 C78 108 52 102 30 116 C46 94 74 100 100 128Z"/>
        <path class="cg-leaf" d="M100 128 C122 108 148 102 170 116 C154 94 126 100 100 128Z"/>
        <!-- Crown leaf (tallest, centre) -->
        <path class="cg-leaf cg-leaf--crown" d="M100 135 C84 105 76 70 100 30 C124 70 116 105 100 135Z"/>
        <!-- Crown vein -->
        <path class="cg-vein" d="M100 135 L100 30"/>
        <!-- Side leaf veins -->
        <path class="cg-vein" d="M100 128 C88 114 66 108 46 116"/>
        <path class="cg-vein" d="M100 128 C112 114 134 108 154 116"/>
        <!-- Decorative circle ring around base -->
        <circle class="cg-ring" cx="100" cy="178" r="12"/>
      </svg>
    </div>

    <!-- Headline -->
    <div class="cg-gate__headline-wrap">
      <h1 class="cg-gate__title">The Cultivators<br><em>Club</em></h1>
      <div class="cg-gate__rule" aria-hidden="true"></div>
      <p class="cg-gate__sub">Members Only</p>
    </div>

    <!-- Status line -->
    <p id="gate-status" class="cg-gate__status">Enter your access code below</p>

    <!-- Password entry -->
    <div id="gate-password-wrap" class="cg-gate__form">
      <div class="cg-gate__input-wrap">
        <input type="password"
               id="gate-password-input"
               placeholder="Access code"
               maxlength="32"
               autocomplete="off"
               spellcheck="false"
               aria-label="Cultivators Club access code">
      </div>
      <p id="gate-input-error" aria-live="polite"></p>
    </div>

    <button id="gate-btn" onclick="crackTheVault()">Enter</button>

    <!-- Discord invite -->
    <div id="gate-hint">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.033.055a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
      </svg>
      <span>Access codes distributed exclusively via Discord</span>
    </div>
    <a href="https://discord.gg/mE8z5Defdc"
       target="_blank"
       rel="noopener noreferrer"
       id="gate-discord-link">
      Join the Discord
      <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

  </div>
</div>

<style>
/* ── Cultivators Club Gate — Premium Botanical ── */

/* CSS custom properties scoped to gate */
#vault-gate {
  --cg-cream:    #EDE8DC;
  --cg-taupe:    #B8A882;
  --cg-dust:     #A89F8C;
  --cg-dark:     #080808;
  --cg-serif:    'Cormorant Garamond', Georgia, serif;
  --cg-sans:     'Montserrat', sans-serif;

  position: fixed;
  inset: 0;
  z-index: 4000;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow-y: auto;
}

#vault-gate__bg {
  position: fixed;
  inset: 0;
  background: rgba(8, 8, 8, 0.97);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

#vault-gate__panel {
  position: relative;
  z-index: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  padding: 48px 32px 56px;
  width: 100%;
  max-width: 460px;
  margin: auto;
}

/* Eyebrow */
.cg-gate__eyebrow {
  font-family: var(--cg-sans);
  font-size: 0.5rem;
  font-weight: 500;
  letter-spacing: 0.45em;
  color: var(--cg-taupe);
  text-transform: uppercase;
  margin: 0 0 36px;
  opacity: 0.8;
}

/* Botanical illustration */
#gate-botanical {
  width: 140px;
  height: 162px;
  margin-bottom: 36px;
}

.cg-botanical {
  width: 100%;
  height: 100%;
  overflow: visible;
}

/* Base state: all strokes fully drawn, muted colour */
.cg-stem {
  stroke: #B8A882;
  stroke-width: 1.4;
  stroke-linecap: round;
  fill: none;
  opacity: 0.7;
}

.cg-tendril {
  stroke: #A89F8C;
  stroke-width: 0.8;
  stroke-linecap: round;
  fill: none;
  opacity: 0.5;
}

.cg-leaf {
  stroke: #C8BE9E;
  stroke-width: 1;
  stroke-linejoin: round;
  stroke-linecap: round;
  fill: none;
  opacity: 0.6;
}

.cg-leaf--crown {
  stroke: #EDE8DC;
  stroke-width: 1.2;
  opacity: 0.75;
}

.cg-leaf--minor {
  stroke: #A89F8C;
  stroke-width: 0.7;
  opacity: 0.4;
}

.cg-vein {
  stroke: #B8A882;
  stroke-width: 0.5;
  stroke-dasharray: 2 3;
  stroke-linecap: round;
  fill: none;
  opacity: 0.35;
}

.cg-ring {
  stroke: #B8A882;
  stroke-width: 0.8;
  fill: none;
  opacity: 0.3;
  stroke-dasharray: 4 4;
}

/* Bloom animation state (applied by JS) */
#gate-botanical.blooming .cg-stem,
#gate-botanical.blooming .cg-tendril,
#gate-botanical.blooming .cg-leaf,
#gate-botanical.blooming .cg-leaf--crown,
#gate-botanical.blooming .cg-leaf--minor,
#gate-botanical.blooming .cg-vein,
#gate-botanical.blooming .cg-ring {
  animation: cgBloom 2.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

#gate-botanical.blooming .cg-leaf--crown {
  animation: cgBloom 2.2s 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

#gate-botanical.blooming .cg-ring {
  animation: cgBloom 1.6s 0.5s ease-out forwards;
}

@keyframes cgBloom {
  0%   { opacity: inherit; filter: none; }
  40%  { opacity: 1; filter: drop-shadow(0 0 6px rgba(237,232,220,0.6)); }
  70%  { opacity: 1; filter: drop-shadow(0 0 12px rgba(237,232,220,0.9)); }
  100% { opacity: 0.9; filter: drop-shadow(0 0 4px rgba(237,232,220,0.4)); }
}

/* Gate headline */
.cg-gate__headline-wrap {
  margin-bottom: 32px;
}

.cg-gate__title {
  font-family: var(--cg-serif);
  font-weight: 300;
  font-size: clamp(2.6rem, 6vw, 3.6rem);
  color: var(--cg-cream);
  line-height: 1.15;
  letter-spacing: 0.01em;
  margin: 0 0 18px;
}

.cg-gate__title em {
  font-style: italic;
  font-weight: 300;
}

.cg-gate__rule {
  width: 48px;
  height: 1px;
  background: var(--cg-taupe);
  margin: 0 auto 16px;
  opacity: 0.5;
}

.cg-gate__sub {
  font-family: var(--cg-sans);
  font-size: 0.55rem;
  font-weight: 400;
  letter-spacing: 0.32em;
  color: var(--cg-dust);
  text-transform: uppercase;
  margin: 0;
}

/* Status line */
.cg-gate__status {
  font-family: var(--cg-sans);
  font-size: 0.5rem;
  font-weight: 300;
  letter-spacing: 0.22em;
  color: var(--cg-dust);
  text-transform: uppercase;
  min-height: 1em;
  margin: 0 0 24px;
  transition: color 0.4s;
}

.cg-gate__status.active {
  color: var(--cg-cream);
}

/* Input form */
.cg-gate__form {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  width: 100%;
  max-width: 280px;
  margin-bottom: 28px;
}

.cg-gate__input-wrap {
  width: 100%;
  border-bottom: 1px solid rgba(184, 168, 130, 0.4);
  transition: border-color 0.3s;
}

.cg-gate__input-wrap:focus-within {
  border-color: rgba(237, 232, 220, 0.7);
}

#gate-password-input {
  width: 100%;
  background: transparent;
  border: none;
  outline: none;
  color: var(--cg-cream);
  font-family: var(--cg-serif);
  font-weight: 300;
  font-size: 1.1rem;
  letter-spacing: 0.12em;
  text-align: center;
  padding: 10px 0 12px;
  caret-color: var(--cg-cream);
}

#gate-password-input::placeholder {
  color: rgba(184, 168, 130, 0.45);
  font-style: italic;
  font-size: 0.95rem;
  letter-spacing: 0.06em;
}

#gate-password-input.denied {
  animation: cgShake 0.4s ease;
  color: #c8876a;
}

@keyframes cgShake {
  0%, 100% { transform: translateX(0); }
  20%       { transform: translateX(-5px); }
  40%       { transform: translateX(5px); }
  60%       { transform: translateX(-3px); }
  80%       { transform: translateX(3px); }
}

#gate-input-error {
  font-family: var(--cg-sans);
  font-size: 0.48rem;
  color: #c8876a;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  min-height: 1em;
}

/* Enter button */
#gate-btn {
  font-family: var(--cg-serif);
  font-style: italic;
  font-weight: 400;
  font-size: 1rem;
  letter-spacing: 0.12em;
  color: var(--cg-dark);
  background: var(--cg-cream);
  border: none;
  padding: 14px 52px;
  border-radius: 1px;
  cursor: pointer;
  transition: background 0.25s, transform 0.2s, opacity 0.2s;
  margin-bottom: 40px;
}

#gate-btn:hover {
  background: #f5f0e8;
  transform: translateY(-1px);
}

#gate-btn:disabled {
  opacity: 0.4;
  pointer-events: none;
}

/* Discord hint */
#gate-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  font-family: var(--cg-sans);
  font-size: 0.48rem;
  font-weight: 300;
  color: var(--cg-dust);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  text-align: center;
  max-width: 320px;
  line-height: 1.8;
  opacity: 0.65;
  margin-bottom: 12px;
}

#gate-discord-link {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-family: var(--cg-sans);
  font-size: 0.5rem;
  font-weight: 400;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--cg-taupe);
  text-decoration: none;
  border-bottom: 1px solid rgba(184, 168, 130, 0.3);
  padding-bottom: 2px;
  transition: color 0.25s, border-color 0.25s;
}

#gate-discord-link:hover {
  color: var(--cg-cream);
  border-color: rgba(237, 232, 220, 0.5);
}

/* Gate exit animation */
#vault-gate.unlocking {
  pointer-events: none;
}

#vault-gate.unlocking #vault-gate__bg {
  animation: cgFade 1s 0.6s ease-out forwards;
}

#vault-gate.unlocking #vault-gate__panel {
  animation: cgSlideUp 0.9s 0.5s ease-out forwards;
}

@keyframes cgFade    { to { opacity: 0; } }
@keyframes cgSlideUp { to { opacity: 0; transform: translateY(-20px); } }

/* ── Mobile gate ── */
@media (max-width: 600px) {
  #vault-gate__panel {
    padding: 40px 24px 52px;
    min-height: 100svh;
    justify-content: center;
  }

  .cg-gate__title {
    font-size: 2.4rem;
  }

  #gate-botanical {
    width: 110px;
    height: 128px;
    margin-bottom: 28px;
  }

  .cg-gate__form {
    max-width: 100%;
  }

  #gate-btn {
    width: 100%;
  }
}
</style>

<script>
(function () {
  /* ── Auth storage key ───────────────────────────────────────── */
  var AUTH_KEY = 'wrc_club_auth_v1';

  /* ── Password check ─────────────────────────────────────────
     Stored as btoa('CULTIVATE') so plaintext is not in source.
     To change the password: replace PASS_HASH with btoa(NEW_PASSWORD)
  ──────────────────────────────────────────────────────────── */
  var PASS_HASH = 'Q1VMVElWQVRF';   /* = btoa('CULTIVATE') */

  /* ── Skip gate if already authenticated ─────────────────── */
  (function checkAuth() {
    try {
      if (localStorage.getItem(AUTH_KEY) === '1') {
        var gate = document.getElementById('vault-gate');
        if (gate) gate.style.display = 'none';
      }
    } catch(e) {}
  })();

  /* ── Unlock animation — botanical bloom ─────────────────── */
  function playUnlockAnimation() {
    var btn      = document.getElementById('gate-btn');
    var status   = document.getElementById('gate-status');
    var gate     = document.getElementById('vault-gate');
    var botanical= document.getElementById('gate-botanical');
    var pwWrap   = document.getElementById('gate-password-wrap');
    var hint     = document.getElementById('gate-hint');
    var discord  = document.getElementById('gate-discord-link');
    var headline = document.querySelector('.cg-gate__headline-wrap');

    /* Fade out form elements gracefully */
    var toFade = [btn, pwWrap, hint, discord];
    toFade.forEach(function(el) {
      if (!el) return;
      el.style.transition = 'opacity 0.5s ease';
      el.style.opacity    = '0';
      el.style.pointerEvents = 'none';
    });

    /* Status messages cycling */
    var msgs  = ['Verifying membership…', 'Cultivating access…', 'Opening the vault…'];
    var mIdx  = 0;
    status.textContent = msgs[0];
    status.classList.add('active');
    var statusTimer = setInterval(function() {
      mIdx++;
      if (mIdx < msgs.length) {
        status.textContent = msgs[mIdx];
      }
    }, 800);

    /* Trigger botanical bloom after short delay */
    setTimeout(function() {
      if (botanical) botanical.classList.add('blooming');
    }, 400);

    /* Final reveal */
    setTimeout(function() {
      clearInterval(statusTimer);
      status.textContent = 'Welcome to the Club';
      status.style.fontStyle   = 'italic';
      status.style.letterSpacing = '0.08em';
      status.style.fontSize    = '0.65rem';
      status.style.color       = '#EDE8DC';
      status.style.fontFamily  = "'Cormorant Garamond', serif";

      setTimeout(function() {
        gate.classList.add('unlocking');
        setTimeout(function() {
          gate.style.display = 'none';
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }, 1400);
      }, 900);
    }, 2800);
  }

  /* ── Access denied feedback ─────────────────────────────── */
  function showDenied() {
    var input  = document.getElementById('gate-password-input');
    var error  = document.getElementById('gate-input-error');
    var status = document.getElementById('gate-status');
    var btn    = document.getElementById('gate-btn');

    status.textContent = 'Incorrect code — please try again';
    status.style.color = '#c8876a';

    if (input) {
      input.classList.add('denied');
      input.value = '';
      setTimeout(function() { input.focus(); }, 50);
    }
    if (error) error.textContent = 'Check your Discord for the current access code';

    setTimeout(function() {
      if (input) input.classList.remove('denied');
      if (error) error.textContent = '';
      status.textContent = 'Enter your access code below';
      status.style.color = '';
      btn.disabled       = false;
    }, 2200);
  }

  /* ── Main entry point (called by button onclick) ─────────── */
  window.crackTheVault = function() {
    var input   = document.getElementById('gate-password-input');
    var entered = input ? input.value.trim().toUpperCase() : '';
    var btn     = document.getElementById('gate-btn');

    if (!entered) {
      if (input) { input.focus(); input.classList.add('denied'); setTimeout(function(){ input.classList.remove('denied'); }, 500); }
      return;
    }

    btn.disabled = true;

    /* Compare against stored hash */
    var match = false;
    try { match = (typeof btoa === 'function') && (btoa(entered) === PASS_HASH); } catch(e) {}

    if (match) {
      try { localStorage.setItem(AUTH_KEY, '1'); } catch(e) {}
      playUnlockAnimation();
    } else {
      showDenied();
    }
  };

  /* ── Enter key support ───────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function() {
    var input = document.getElementById('gate-password-input');
    if (input) {
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') window.crackTheVault();
      });
      /* Auto-focus the input if gate is visible */
      try {
        if (localStorage.getItem(AUTH_KEY) !== '1') {
          setTimeout(function() { input.focus(); }, 600);
        }
      } catch(e) {}
    }
  });
})();
</script>
{%- endif -%}


<!-- ============================================================
