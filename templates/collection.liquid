  letter-spacing: 0.04em;
  line-height: 1.7;
}

.wrc-entries .club-entry__cta {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  font-weight: 700;
  color: var(--clr-silver);
  border-bottom: none;
  padding-bottom: 0;
  letter-spacing: 0.18em;
}

.wrc-entries .club-entry:hover .club-entry__cta { color: var(--clr-green); gap: 12px; }

/* WRC bracket corners */
.club-entry__bracket {
  position: absolute;
  width: 20px; height: 20px;
  border-color: rgba(200,205,212,0.35);
  border-style: solid;
  z-index: 2;
  transition: border-color 0.3s;
}
.club-entry__bracket--tl { top: 10px; left: 10px; border-width: 1px 0 0 1px; }
.club-entry__bracket--br { bottom: 10px; right: 10px; border-width: 0 1px 1px 0; }
.wrc-entries .club-entry:hover .club-entry__bracket { border-color: rgba(0,255,65,0.5); }

/* WRC count badge */
.club-entry__count-badge {
  position: absolute;
  top: 10px; left: 10px;
  z-index: 3;
  background: rgba(0,0,0,0.85);
  border: 1px solid var(--clr-border);
  color: var(--clr-silver-dim);
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 700;
  padding: 3px 8px;
  letter-spacing: 0.05em;
  display: flex; align-items: baseline; gap: 4px;
}
.club-entry__count-badge span { font-size: 0.42rem; letter-spacing: 0.18em; }

/* WRC top-line sweep */
.wrc-entries .club-entry::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--clr-green), transparent);
  transform: scaleX(0); transition: transform 0.4s ease; z-index: 4;
}
.wrc-entries .club-entry:hover::before { transform: scaleX(1); }

/* ── Mobile ── */
@media (max-width: 900px) {
  .wrc-entries { grid-template-columns: 1fr 1fr !important; }
}

@media (max-width: 768px) {
  /* Club: single column */
  .club-entries:not(.wrc-entries) {
    grid-template-columns: 1fr;
    background: transparent;
    gap: 1px;
  }

  .club-entry__body { padding: 24px 24px 32px; }
  .club-entry__title { font-size: 2rem; }
  .club-entry__visual { aspect-ratio: 16 / 9; }

  /* WRC: 2-col compact */
  .wrc-entries .club-entry__visual { aspect-ratio: 1 / 1; }
  .wrc-entries .club-entry__body { padding: 10px 12px 12px; gap: 6px; }
  .wrc-entries .club-entry__desc { display: none; }
  .wrc-entries .club-entry__title { font-size: clamp(0.72rem, 3.2vw, 1rem); margin-bottom: 0; }
  .wrc-entries .club-entry__eyebrow { font-size: 0.42rem; margin-bottom: 4px; }
