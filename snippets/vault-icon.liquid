{%- comment -%}
  Reusable vault SVG icon component.
  Usage: {% render 'vault-icon', size: 44 %}
{%- endcomment -%}

{%- assign icon_size = size | default: 44 -%}

<svg viewBox="0 0 44 44" width="{{ icon_size }}" height="{{ icon_size }}" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <circle cx="22" cy="22" r="20" stroke="#c8cdd4" stroke-width="2"/>
  <circle cx="22" cy="22" r="15" stroke="#1e1e1e" stroke-width="1" stroke-dasharray="3 3"/>
  <circle cx="22" cy="22" r="11" stroke="#00ff41" stroke-width="1.5"/>
  <!-- Tick marks -->
  <line x1="22" y1="4"  x2="22" y2="9"  stroke="#00ff41" stroke-width="2"   stroke-linecap="round"/>
  <line x1="22" y1="35" x2="22" y2="40" stroke="#7a8090" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="4"  y1="22" x2="9"  y2="22" stroke="#7a8090" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="35" y1="22" x2="40" y2="22" stroke="#7a8090" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Center -->
  <circle cx="22" cy="22" r="5" fill="#111111" stroke="#00ff41" stroke-width="1.5"/>
  <circle cx="22" cy="22" r="2" fill="#00ff41"/>
  <!-- Handle -->
  <rect x="27" y="20" width="8" height="4" rx="2" fill="#c8cdd4" stroke="#7a8090" stroke-width="0.5"/>
</svg>
