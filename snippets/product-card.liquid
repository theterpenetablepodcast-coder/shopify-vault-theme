{%- comment -%}
  Renders a vault-styled product card.
  Usage: {% render 'product-card', product: product, show_vendor: true %}
{%- endcomment -%}

{%- liquid
  assign product_url = product.url | within: collection
  assign featured_image = product.featured_image
  assign first_available_variant = product.first_available_variant
  assign price = product.price
  assign compare_price = product.compare_at_price
  assign on_sale = false
  if compare_price > price
    assign on_sale = true
  endif
  assign sold_out = true
  if product.available
    assign sold_out = false
  endif
  assign seven_days_ago = 'now' | date: '%s' | minus: 604800
  assign created_at_unix = product.created_at | date: '%s' | plus: 0
  assign is_new = false
  if created_at_unix > seven_days_ago
    assign is_new = true
  endif
  assign is_past_drop = false
  for tag in product.tags
    if tag == 'past-drop'
      assign is_past_drop = true
      break
    endif
  endfor
-%}

<article class="vault-card{% if is_past_drop %} vault-card--past-drop{% endif %}" data-reveal>

  {%- comment -%} Badge {%- endcomment -%}
  {%- if is_past_drop -%}
    <span class="vault-card__badge badge--past-drop">PAST DROP</span>
  {%- elsif sold_out -%}
    <span class="vault-card__badge badge--classified">CLASSIFIED</span>
  {%- elsif on_sale -%}
    <span class="vault-card__badge badge--sale">SALE</span>
  {%- elsif is_new -%}
    <span class="vault-card__badge badge--new">NEW</span>
  {%- endif -%}

  {%- comment -%} Image {%- endcomment -%}
  <div class="vault-card__image-wrap">
    {%- if featured_image -%}
      <a href="{{ product_url }}" tabindex="-1" aria-hidden="true">
        <img src="{{ featured_image | img_url: '600x600', crop: 'center' }}"
             alt="{{ featured_image.alt | escape }}"
             width="600"
             height="600"
             loading="lazy">
      </a>
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}

    <div class="vault-card__overlay">
      <a href="{{ product_url }}" class="vault-card__quick-add">
        {%- if is_past_drop -%}
          ARCHIVED — SECURED BY THE FEW
        {%- elsif sold_out -%}
          SOLD OUT
        {%- else -%}
          QUICK VIEW
        {%- endif -%}
      </a>
    </div>
  </div>

  {%- comment -%} Card body {%- endcomment -%}
  <div class="vault-card__body">
    {%- if show_vendor and product.vendor != blank -%}
      <p class="vault-card__category">{{ product.vendor | upcase }}</p>
    {%- elsif product.type != blank -%}
      <p class="vault-card__category">{{ product.type | upcase }}</p>
    {%- else -%}
      <p class="vault-card__category">VAULT</p>
    {%- endif -%}

    <h3 class="vault-card__title">
      <a href="{{ product_url }}">{{ product.title }}</a>
    </h3>

    <div class="vault-card__footer">
      <div>
        <span class="vault-card__price">
          {%- if on_sale -%}
            {{ price | money }}
          {%- else -%}
            {{ price | money }}
          {%- endif -%}
        </span>
        {%- if on_sale -%}
          <span class="vault-card__price--compare">{{ compare_price | money }}</span>
        {%- endif -%}
      </div>

      {%- unless sold_out or is_past_drop -%}
        <form method="post" action="/cart/add" data-product-form>
          <input type="hidden" name="id" value="{{ first_available_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button type="submit" class="vault-card__add" data-atc aria-label="Add {{ product.title }} to cart">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="12" y1="5" x2="12" y2="19"/>
              <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
          </button>
        </form>
      {%- endunless -%}
    </div>
  </div>

</article>
