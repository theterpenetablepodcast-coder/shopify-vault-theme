<div class="marquee-band" aria-hidden="true">
  <div class="marquee-band__track" id="marquee-track">
    {%- assign marquee_items = '' -%}
    {%- for block in section.blocks -%}
      {%- if block.settings.text != blank -%}
        {%- assign marquee_items = marquee_items | append: block.settings.text | append: '|||' -%}
      {%- endif -%}
    {%- else -%}
      {%- assign marquee_items = 'WRC|||WildRoot Cultivars|||The Basin Breeding Co|||Curated Selections|||Australian Owned|||Shipped Locally|||' -%}
    {%- endfor -%}

    {%- assign item_arr = marquee_items | split: '|||' -%}
    {%- comment -%} Render 3 passes so shuffle JS has enough width to loop {%- endcomment -%}
    {%- for pass in (1..3) -%}
      {%- for item in item_arr -%}
        {%- if item != blank -%}
          <span class="marquee-band__item">
            <span class="marquee-band__dot"></span>
            {{ item | strip | upcase }}
          </span>
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee Band",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "item",
      "name": "Marquee item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Band",
      "blocks": [
        { "type": "item", "settings": { "text": "WRC" } },
        { "type": "item", "settings": { "text": "WildRoot Cultivars" } },
        { "type": "item", "settings": { "text": "The Basin Breeding Co" } },
        { "type": "item", "settings": { "text": "Curated Selections" } },
        { "type": "item", "settings": { "text": "Australian Owned" } },
        { "type": "item", "settings": { "text": "Shipped Locally" } }
      ]
    }
  ]
}
{% endschema %}
