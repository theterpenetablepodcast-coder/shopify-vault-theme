<section class="vault-hero" style="{% if section.settings.bg_image != blank %}--hero-bg: url('{{ section.settings.bg_image | img_url: '2000x' }}'){% endif %}">

  {%- if section.settings.bg_image != blank -%}
    <style>
      .vault-hero { background-image: var(--hero-bg); background-size: cover; background-position: center; }
      .vault-hero::after { content:''; position:absolute; inset:0; background:rgba(0,0,0,0.75); z-index:1; }
    </style>
  {%- endif -%}

  <!-- Matrix rain canvas -->
  <canvas id="matrix-canvas" aria-hidden="true"></canvas>

  <div class="vault-hero__content" data-reveal>

    <!-- Vault door graphic -->
    <div class="vault-door-wrap" aria-hidden="true">
      <svg viewBox="0 0 220 220" fill="none" xmlns="http://www.w3.org/2000/svg">

        <!-- Outer casing -->
        <rect x="10" y="10" width="200" height="200" rx="8" class="vault-door__body"/>

        <!-- Bolt holes — corners -->
        <circle cx="28"  cy="28"  r="7" fill="#0d0d0d" stroke="#7a8090" stroke-width="1.5"/>
        <circle cx="192" cy="28"  r="7" fill="#0d0d0d" stroke="#7a8090" stroke-width="1.5"/>
        <circle cx="28"  cy="192" r="7" fill="#0d0d0d" stroke="#7a8090" stroke-width="1.5"/>
        <circle cx="192" cy="192" r="7" fill="#0d0d0d" stroke="#7a8090" stroke-width="1.5"/>

        <!-- Lock bolts (edges) -->
        <rect x="4"   y="94"  width="14" height="12" rx="3" fill="#1e1e1e" stroke="#c8cdd4" stroke-width="1.5"/>
        <rect x="202" y="94"  width="14" height="12" rx="3" fill="#1e1e1e" stroke="#c8cdd4" stroke-width="1.5"/>
        <rect x="94"  y="4"   width="12" height="14" rx="3" fill="#1e1e1e" stroke="#c8cdd4" stroke-width="1.5"/>
        <rect x="94"  y="202" width="12" height="14" rx="3" fill="#1e1e1e" stroke="#c8cdd4" stroke-width="1.5"/>

        <!-- Main dial ring -->
        <circle cx="110" cy="110" r="76" class="vault-door__ring"/>
        <circle cx="110" cy="110" r="70" stroke="#1e1e1e" stroke-width="1" fill="none"/>
        <circle cx="110" cy="110" r="56" class="vault-door__inner-ring"/>

        <!-- Rotating dial group -->
        <g class="vault-dial-group">
          <!-- Dial base -->
          <circle cx="110" cy="110" r="50" class="vault-door__dial"/>

          <!-- 40 tick marks around dial -->
          {%- for i in (0..39) -%}
            {%- assign a = i | times: 9 -%}
            {%- assign mod5 = i | modulo: 5 -%}
            {%- assign mod10 = i | modulo: 10 -%}
            {%- if mod10 == 0 -%}
              <line x1="110" y1="62" x2="110" y2="70"
                stroke="#00ff41" stroke-width="2"
                transform="rotate({{ a }}, 110, 110)"/>
            {%- elsif mod5 == 0 -%}
              <line x1="110" y1="63" x2="110" y2="70"
                stroke="#c8cdd4" stroke-width="1.5"
                transform="rotate({{ a }}, 110, 110)"/>
            {%- else -%}
              <line x1="110" y1="65" x2="110" y2="69"
                stroke="#1e1e1e" stroke-width="1"
                transform="rotate({{ a }}, 110, 110)"/>
            {%- endif -%}
          {%- endfor -%}

          <!-- Spokes -->
          <g class="vault-spokes">
            <line x1="110" y1="70" x2="110" y2="90" stroke="#7a8090" stroke-width="1.5"/>
            <line x1="110" y1="130" x2="110" y2="150" stroke="#7a8090" stroke-width="1.5"/>
            <line x1="70"  y1="110" x2="90"  y2="110" stroke="#7a8090" stroke-width="1.5"/>
            <line x1="130" y1="110" x2="150" y2="110" stroke="#7a8090" stroke-width="1.5"/>
            <line x1="81"  y1="81"  x2="95"  y2="95"  stroke="#7a8090" stroke-width="1"/>
            <line x1="125" y1="125" x2="139" y2="139" stroke="#7a8090" stroke-width="1"/>
            <line x1="139" y1="81"  x2="125" y2="95"  stroke="#7a8090" stroke-width="1"/>
            <line x1="95"  y1="125" x2="81"  y2="139" stroke="#7a8090" stroke-width="1"/>
          </g>

          <!-- Dial pointer -->
          <polygon points="110,60 107,68 113,68" fill="#00ff41" filter="url(#glow)"/>
        </g>

        <!-- Center hub (static) -->
        <circle cx="110" cy="110" r="18" fill="#0d0d0d" stroke="#c8cdd4" stroke-width="2"/>
        <circle cx="110" cy="110" r="10" fill="#111111" stroke="#00ff41" stroke-width="1.5"/>

        <!-- Handle -->
        <g class="vault-handle">
          <rect x="148" y="104" width="26" height="12" rx="6" fill="#c8cdd4" stroke="#7a8090"/>
          <circle cx="174" cy="110" r="5" fill="#7a8090"/>
        </g>

        <!-- Glow filter -->
        <defs>
          <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="blur"/>
            <feMerge>
              <feMergeNode in="blur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
        </defs>
      </svg>
    </div>
    <!-- / vault door -->

    <!-- Eyebrow -->
    <p class="hero-eyebrow">
      {{ section.settings.eyebrow | default: 'CLASSIFIED ACCESS ONLY' }}
    </p>

    <!-- Title -->
    <h1 class="hero-title">
      {%- assign words = section.settings.title | default: 'UNLOCK THE VAULT' | split: ' ' -%}
      {%- for word in words -%}
        {%- if forloop.last -%}
          <span class="highlight" data-scramble>{{ word }}</span>
        {%- else -%}
          {{ word }}{%- unless forloop.last %} {% endunless -%}
        {%- endif -%}
      {%- endfor -%}
    </h1>

    <!-- Subtitle -->
    {%- if section.settings.subtitle != blank -%}
      <p class="hero-subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    <!-- CTA buttons -->
    <div class="hero-cta">
      {%- if section.settings.btn_primary_label != blank -%}
        <a href="{{ section.settings.btn_primary_url | default: routes.collections_url }}"
           class="btn btn--primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          {{ section.settings.btn_primary_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.btn_secondary_label != blank -%}
        <a href="{{ section.settings.btn_secondary_url | default: routes.all_products_collection_url }}"
           class="btn btn--outline">
          {{ section.settings.btn_secondary_label }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    <!-- Live access ticker -->
    <div class="access-ticker" aria-hidden="true">
      <span>ACCESS CODE:</span>
      <span class="access-ticker__code">--:--.--</span>
      <span>/// SECURE CHANNEL ACTIVE</span>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Hero — Vault",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image (optional)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "CLASSIFIED ACCESS ONLY"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "UNLOCK THE VAULT"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Exclusive products secured behind vault-grade protection. Enter the combination. Access your collection."
    },
    {
      "type": "text",
      "id": "btn_primary_label",
      "label": "Primary button text",
      "default": "ENTER THE VAULT"
    },
    {
      "type": "url",
      "id": "btn_primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "btn_secondary_label",
      "label": "Secondary button text",
      "default": "VIEW ALL PRODUCTS"
    },
    {
      "type": "url",
      "id": "btn_secondary_url",
      "label": "Secondary button URL"
    }
  ],
  "presets": [
    { "name": "Hero — Vault" }
  ]
}
{% endschema %}
