{% if section.settings.enabled %}
<div class="announcement-bar" role="banner" aria-label="Site announcement">
  <div class="announcement-bar__track" id="announcement-track" aria-hidden="true">
    {%- assign items = section.settings.text_1 | append: '|||' | append: section.settings.text_2 | append: '|||' | append: section.settings.text_3 | append: '|||' | append: section.settings.text_4 | append: '|||' | append: section.settings.text_5 | append: '|||' | append: section.settings.text_6 | split: '|||' -%}
    {%- for i in (1..4) -%}
      {%- for item in items -%}
        {%- if item != blank -%}
          <span class="announcement-bar__text">
            {{ item | strip }}
            <span class="announcement-bar__sep">///</span>
          </span>
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Message 1",
      "default": "WRC"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Message 2",
      "default": "WildRoot Cultivars"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Message 3",
      "default": "The Basin Breeding Co"
    },
    {
      "type": "text",
      "id": "text_4",
      "label": "Message 4",
      "default": "Curated Selections"
    },
    {
      "type": "text",
      "id": "text_5",
      "label": "Message 5",
      "default": "Australian Owned"
    },
    {
      "type": "text",
      "id": "text_6",
      "label": "Message 6",
      "default": "Shipped Locally"
    }
  ],
  "presets": [
    { "name": "Announcement Bar" }
  ]
}
{% endschema %}
