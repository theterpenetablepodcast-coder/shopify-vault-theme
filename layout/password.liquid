<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — ACCESS RESTRICTED</title>
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body style="background:var(--clr-black);min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;">

  <!-- Scanlines -->
  <div id="scanlines" aria-hidden="true"></div>
  <div id="vault-cursor" aria-hidden="true"></div>
  <div id="cursor-trail" aria-hidden="true"></div>
  <div id="vault-toast" aria-live="polite"></div>

  <!-- Matrix canvas behind everything -->
  <canvas id="matrix-canvas" style="position:fixed;inset:0;width:100%;height:100%;opacity:0.15;" aria-hidden="true"></canvas>

  <!-- Password gate -->
  <div style="position:relative;z-index:10;text-align:center;max-width:480px;padding:0 24px;width:100%;">

    <!-- Vault icon -->
    <div style="width:140px;height:140px;margin:0 auto 40px;animation:dialSpin 12s linear infinite;filter:drop-shadow(0 0 20px rgba(0,255,65,0.5));">
      {%- render 'vault-icon', size: 140 -%}
    </div>

    <p style="font-family:var(--font-mono);font-size:0.65rem;color:var(--clr-green);letter-spacing:0.4em;text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;justify-content:center;gap:10px;">
      <span style="display:block;width:32px;height:1px;background:var(--clr-green);"></span>
      RESTRICTED ACCESS
      <span style="display:block;width:32px;height:1px;background:var(--clr-green);"></span>
    </p>

    <h1 style="font-family:var(--font-display);font-size:clamp(2rem,6vw,3.5rem);font-weight:900;color:var(--clr-white);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:12px;" data-scramble>
      {{ shop.name }}
    </h1>

    <p style="font-family:var(--font-mono);font-size:0.75rem;color:var(--clr-silver-dim);letter-spacing:0.08em;margin-bottom:40px;line-height:1.8;">
      {{ shop.password_message | default: 'THIS VAULT IS CURRENTLY LOCKED. ENTER YOUR ACCESS CODE TO PROCEED.' }}
    </p>

    <!-- Password form -->
    {%- form 'storefront_password' -%}
      <div style="border:1px solid var(--clr-green);border-radius:var(--radius);overflow:hidden;box-shadow:var(--glow-green);margin-bottom:20px;">
        <input type="password"
               name="password"
               id="Password"
               style="display:block;width:100%;background:rgba(0,0,0,0.8);border:none;color:var(--clr-white);font-family:var(--font-mono);font-size:0.8rem;padding:16px 20px;text-align:center;letter-spacing:0.3em;outline:none;"
               placeholder="• • • • • • • •"
               autofocus
               aria-label="Store password">
      </div>

      {%- if form.errors -%}
        <p style="font-family:var(--font-mono);font-size:0.65rem;color:#ff2222;letter-spacing:0.15em;margin-bottom:16px;text-transform:uppercase;">
          ACCESS DENIED — INVALID CODE
        </p>
      {%- endif -%}

      <button type="submit"
              class="btn btn--primary"
              style="width:100%;justify-content:center;height:50px;font-size:0.8rem;letter-spacing:0.3em;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="11" width="18" height="11" rx="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        UNLOCK VAULT
      </button>
    {%- endform -%}

    <!-- Access ticker -->
    <div style="margin-top:40px;font-family:var(--font-mono);font-size:0.6rem;color:var(--clr-silver-dim);letter-spacing:0.2em;display:flex;align-items:center;justify-content:center;gap:8px;">
      <span>SECURE CHANNEL</span>
      <span style="color:var(--clr-green);" class="access-ticker__code">--:--.--</span>
      <span>ACTIVE</span>
    </div>

  </div>

  <script src="{{ 'vault.js' | asset_url }}" defer></script>
</body>
</html>
