<!doctype html>
{%- comment -%}
  Detect Cultivators Club pages early so we can use is_club_page
  anywhere in theme.liquid including <head> inline styles.
{%- endcomment -%}
{%- assign is_club_page = false -%}
{%- if template.name == 'collection' -%}
  {%- if collection.handle contains 'cultivator' or collection.handle == 'the-uniform' or collection.handle == 'the-drops' -%}
    {%- assign is_club_page = true -%}
  {%- endif -%}
{%- elsif template.name == 'product' -%}
  {%- for col in product.collections -%}
    {%- if col.handle contains 'cultivator' or col.handle == 'the-uniform' or col.handle == 'the-drops' -%}
      {%- assign is_club_page = true -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if product.vendor contains 'Cultivat' -%}
    {%- assign is_club_page = true -%}
  {%- endif -%}
{%- endif -%}

<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | img_url: '32x32' }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <!-- Canonical URL -->
  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Open Graph -->
  {%- assign og_title       = page_title | default: shop.name -%}
  {%- assign og_description = page_description | default: shop.description | default: shop.name -%}
  {%- if template.name == 'product' -%}
    {%- assign og_image = product.featured_image | img_url: '1200x630', crop: 'center' -%}
    {%- assign og_type  = 'product' -%}
  {%- elsif template.name == 'collection' and collection.image -%}
    {%- assign og_image = collection.image | img_url: '1200x630', crop: 'center' -%}
    {%- assign og_type  = 'website' -%}
  {%- elsif template.name == 'article' and article.image -%}
    {%- assign og_image = article.image | img_url: '1200x630', crop: 'center' -%}
    {%- assign og_type  = 'article' -%}
  {%- else -%}
    {%- assign og_image = settings.share_image | img_url: '1200x630', crop: 'center' -%}
    {%- assign og_type  = 'website' -%}
  {%- endif -%}
  <meta property="og:site_name"   content="{{ shop.name | escape }}">
  <meta property="og:type"        content="{{ og_type }}">
  <meta property="og:title"       content="{{ og_title | escape }}">
  <meta property="og:description" content="{{ og_description | escape }}">
  <meta property="og:url"         content="{{ canonical_url }}">
  {%- if og_image != blank -%}
    <meta property="og:image"       content="https:{{ og_image }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
  {%- endif -%}
  {%- if template.name == 'product' -%}
    <meta property="og:price:amount"   content="{{ product.price | money_without_currency }}">
    <meta property="og:price:currency" content="{{ shop.currency }}">
  {%- endif -%}

  <!-- Twitter / X Card -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="{{ og_title | escape }}">
  <meta name="twitter:description" content="{{ og_description | escape }}">
  {%- if og_image != blank -%}
    <meta name="twitter:image" content="https:{{ og_image }}">
  {%- endif -%}

  {{ content_for_header }}

  <!-- Preconnect fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {%- if is_club_page -%}
  <!-- ── Cultivators Club: override every green accent inline (cache-safe) ── -->
  <style>
    :root {
      --clr-green:  #B8A882;
      --glow-green: 0 0 6px rgba(184,168,130,0.2), 0 0 14px rgba(184,168,130,0.08);
    }
    /* Stop the spinning cursor ring — static taupe instead */
    #vault-cursor::before { animation: none !important; border-color: rgba(184,168,130,0.65) !important; box-shadow: none !important; }
    #vault-cursor::after  { background: #B8A882 !important; box-shadow: none !important; }
    #cursor-trail         { background: rgba(184,168,130,0.35) !important; }
    /* Product badge: no green box */
    .product-info__badge  { background: transparent !important; border: none !important; color: #A89F8C !important; font-family: 'Montserrat',sans-serif !important; font-size: 0.48rem !important; letter-spacing: 0.4em !important; padding: 0 !important; }
    /* Price: taupe, no glow */
    .price-current        { color: #B8A882 !important; text-shadow: none !important; font-family: 'Montserrat',sans-serif !important; font-weight: 300 !important; }
    /* Active variant buttons */
    .variant-btn.active   { background: #EDE8DC !important; border-color: #EDE8DC !important; color: #080808 !important; box-shadow: none !important; }
    /* Gallery corners */
    .gallery-corner       { border-color: rgba(184,168,130,0.3) !important; }
    /* Filter panel LED dot */
    .filter-panel::before,
    .filter-panel__title::before { background: #B8A882 !important; box-shadow: none !important; }
    /* Collection sort/count bar */
    .collection-count     { color: #A89F8C !important; }
    /* Any remaining btn--primary on club pages: cream */
    .btn--primary:not(.cart-drawer__checkout-btn) { background: #EDE8DC !important; color: #080808 !important; border-color: #EDE8DC !important; box-shadow: none !important; font-family: 'Montserrat',sans-serif !important; }
    /* Collection card overrides */
    .vault-card__price          { color: #B8A882 !important; font-family: 'Montserrat',sans-serif !important; font-weight: 300 !important; font-size: 0.85rem !important; }
    .vault-card__category       { color: #A89F8C !important; font-family: 'Montserrat',sans-serif !important; font-size: 0.48rem !important; letter-spacing: 0.32em !important; }
    .vault-card__title          { font-family: 'Cormorant Garamond',Georgia,serif !important; font-size: 1rem !important; font-weight: 300 !important; letter-spacing: 0.02em !important; text-transform: none !important; color: #EDE8DC !important; }
    .vault-card__add            { border-color: rgba(184,168,130,0.2) !important; color: #A89F8C !important; }
    .vault-card__add:hover      { border-color: rgba(237,232,220,0.45) !important; color: #EDE8DC !important; background: rgba(237,232,220,0.05) !important; box-shadow: none !important; }
    .vault-card__footer         { border-top-color: rgba(184,168,130,0.12) !important; }
    .vault-card                 { background: #0c0b09 !important; border-color: rgba(184,168,130,0.1) !important; }
    .vault-card:hover           { border-color: rgba(184,168,130,0.28) !important; box-shadow: 0 8px 32px rgba(0,0,0,0.8) !important; }
    .vault-card::after          { background: rgba(184,168,130,0.45) !important; box-shadow: none !important; animation: none !important; }
    /* Filter panel */
    .filter-panel__title        { color: #B8A882 !important; }
    .collection-count           { color: #A89F8C !important; }
  </style>
  {%- endif -%}

  <!-- Structured data -->
  {%- if template.name == 'product' -%}
    <script type="application/ld+json">
    {
      "@context": "http://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | json }},
      "image": {{ product.featured_image | img_url: '800x800' | json }},
      "offers": {
        "@type": "Offer",
        "priceCurrency": {{ shop.currency | json }},
        "price": {{ product.price | money_without_currency | json }},
        "availability": "{% if product.available %}InStock{% else %}OutOfStock{% endif %}"
      }
    }
    </script>
  {%- endif -%}
</head>

<body class="template--{{ template.name }} template--{{ template | replace: '.', '-' }}{% if is_club_page %} cg-page{% endif %}">

  <!-- ── PRELOADER ── -->
  {%- if is_club_page -%}

  <!-- Club preloader — botanical / cream -->
  <div id="vault-preloader" role="status" aria-label="Loading">
    <div class="cg-preloader__ring-wrap">
      <svg viewBox="0 0 180 180" fill="none" aria-hidden="true">
        <!-- Faint outer ring -->
        <circle cx="90" cy="90" r="76" stroke="rgba(184,168,130,0.12)" stroke-width="0.8"/>
        <!-- Animated cream arc -->
        <circle class="dial-arc cg-preloader__arc" cx="90" cy="90" r="76"
                stroke="#EDE8DC" stroke-width="1" stroke-linecap="round"
                stroke-dasharray="477.5" stroke-dashoffset="477.5"/>
        <!-- Inner ring -->
        <circle cx="90" cy="90" r="58" stroke="rgba(184,168,130,0.07)" stroke-width="0.5"/>
        <!-- Four subtle tick marks at cardinal points -->
        <line x1="90" y1="14" x2="90" y2="22" stroke="rgba(184,168,130,0.3)" stroke-width="0.8" />
        <line x1="90" y1="158" x2="90" y2="166" stroke="rgba(184,168,130,0.3)" stroke-width="0.8" />
        <line x1="14" y1="90" x2="22" y2="90" stroke="rgba(184,168,130,0.3)" stroke-width="0.8" />
        <line x1="158" y1="90" x2="166" y2="90" stroke="rgba(184,168,130,0.3)" stroke-width="0.8" />
      </svg>
      <div class="cg-preloader__center dial-center">
        <span class="dial-percent cg-preloader__pct">0%</span>
        <span class="dial-label cg-preloader__brand">The Cultivators Club</span>
      </div>
    </div>
    <p class="preloader-status cg-preloader__status">Preparing your experience…</p>
  </div>

  {%- else -%}

  <!-- Standard vault preloader -->
  <div id="vault-preloader" role="status" aria-label="Loading vault">
    <div class="preloader-dial">
      <svg viewBox="0 0 180 180" aria-hidden="true">
        <circle class="dial-ring" cx="90" cy="90" r="80"/>
        {%- for i in (1..40) -%}
          {%- assign angle = i | times: 9 -%}
          {%- assign is_major = i | modulo: 5 -%}
          <line
            x1="90" y1="{% if is_major == 0 %}14{% else %}18{% endif %}"
            x2="90" y2="{% if is_major == 0 %}24{% else %}22{% endif %}"
            stroke="{% if is_major == 0 %}#00ff41{% else %}#1e1e1e{% endif %}"
            stroke-width="{% if is_major == 0 %}2{% else %}1{% endif %}"
            transform="rotate({{ angle }}, 90, 90)"
          />
        {%- endfor -%}
        <circle class="dial-arc" cx="90" cy="90" r="80"/>
      </svg>
      <div class="preloader-dial__center dial-center">
        <span class="dial-percent">0%</span>
        <span class="dial-label">VAULT ACCESS</span>
      </div>
    </div>
    <div class="preloader-status">INITIALISING VAULT SYSTEMS...</div>
    <div class="preloader-bars" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span>
    </div>
  </div>

  {%- endif -%}
  <!-- / PRELOADER -->

  <!-- ── SCANLINES OVERLAY ── -->
  <div id="scanlines" aria-hidden="true"></div>

  <!-- ── CUSTOM CURSOR ── -->
  <div id="vault-cursor" aria-hidden="true"></div>
  <div id="cursor-trail" aria-hidden="true"></div>

  <!-- ── ACCESS OVERLAY ── -->
  <div id="access-overlay" class="access-overlay" aria-hidden="true" role="status">
    <div class="access-overlay__text">ACCESS GRANTED</div>
  </div>

  <!-- ── TOAST CONTAINER ── -->
  <div id="vault-toast" aria-live="polite" aria-atomic="false"></div>

  <!-- ── CART DRAWER ── -->
  <div id="cart-drawer" class="cart-drawer" role="dialog" aria-modal="true" aria-labelledby="cdr-title">
    <div class="cart-drawer__header">
      <div>
        <span class="cart-drawer__title" id="cdr-title">YOUR VAULT</span>
        <span class="cart-drawer__item-count" id="cdr-count"></span>
      </div>
      <button class="cart-drawer__close" id="cdr-close" aria-label="Close cart">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="cart-drawer__ship-bar">
      <div class="cart-drawer__ship-track">
        <div class="cart-drawer__ship-fill" id="cdr-ship-fill" style="width:0%"></div>
      </div>
      <p class="cart-drawer__ship-msg" id="cdr-ship-msg"></p>
    </div>
    <div class="cart-drawer__body" id="cdr-body"></div>
    <div class="cart-drawer__footer">
      <div class="cart-drawer__subtotal">
        <span class="cart-drawer__subtotal-label">SUBTOTAL</span>
        <span class="cart-drawer__subtotal-val" id="cdr-subtotal">—</span>
      </div>
      <p class="cart-drawer__ship-note">SHIPPING CALCULATED AT CHECKOUT</p>
      <button type="button" class="btn btn--primary cart-drawer__checkout-btn" id="cdr-checkout">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="11" width="18" height="11" rx="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        SECURE CHECKOUT
      </button>
      <a href="{{ routes.cart_url }}" class="btn btn--outline cart-drawer__view-cart">VIEW FULL VAULT</a>
    </div>
  </div>
  <div id="cdr-overlay" class="cart-drawer-overlay" aria-hidden="true"></div>

  <!-- ── ANNOUNCEMENT BAR ── -->
  {%- sections 'announcement-bar' -%}

  <!-- ── SITE HEADER ── -->
  {%- sections 'header' -%}

  <!-- ── MOBILE NAV ── -->
  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
    <ul class="mobile-nav__list">
      {%- for link in linklists.main-menu.links -%}
        <li>
          <a class="mobile-nav__link" href="{{ link.url }}">{{ link.title }}</a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>

  <!-- ── MAIN CONTENT ── -->
  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  <!-- ── FOOTER ── -->
  {%- sections 'footer' -%}

  <!-- ── VAULT RADIO ── -->
  {%- if settings.music_url != blank -%}
  <div id="vault-radio"
       class="vault-radio"
       aria-label="Vault Radio music player"
       data-yt="{{ settings.music_url | escape }}">
    <div class="vault-radio__eq" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
    </div>
    <div class="vault-radio__info">
      <span class="vault-radio__label">VAULT RADIO</span>
      <span class="vault-radio__track" id="vr-track">{{ settings.music_title | default: 'TRAP INSTRUMENTAL' | upcase }}</span>
    </div>
    <div class="vault-radio__controls">
      <button type="button" id="vr-play" class="vault-radio__btn" aria-label="Play">
        <svg class="vr-icon-play" width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21"/></svg>
        <svg class="vr-icon-pause" width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      </button>
      <button type="button" id="vr-mute" class="vault-radio__btn" aria-label="Mute">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
          <path class="vr-vol-lines" d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/>
        </svg>
      </button>
    </div>
  </div>
  <!-- Hidden YouTube player — 1×1px in corner, no opacity (opacity:0 blocks Chrome media) -->
  <div id="vr-yt-container"
       style="position:fixed;bottom:0;right:0;width:1px;height:1px;overflow:hidden;pointer-events:none;z-index:-1;"
       aria-hidden="true">
    <div id="vr-yt-player"></div>
  </div>
  {%- endif -%}

  <!-- ── BACK TO TOP ── -->
  <button id="back-to-top" class="back-to-top" aria-label="Back to top" style="display:none">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path d="M18 15l-6-6-6 6"/>
    </svg>
  </button>

  <!-- ── SCRIPTS ── -->
  <script src="{{ 'vault.js' | asset_url }}" defer></script>

  <!-- Cart handled by vault.js -->

</body>
</html>
